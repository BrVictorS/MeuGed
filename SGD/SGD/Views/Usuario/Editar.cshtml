@using SGD.Dtos.Usuarios
@model UsuarioEditarDto

<script src="https://cdn.tailwindcss.com"></script>

<script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>

<div class="container mx-auto px-4 py-8 max-w-6xl">

    <div class="mb-6 border-b border-gray-200 pb-4">
        <h2 class="text-3xl font-bold text-gray-800">Editar Usuário</h2>
        <p class="text-gray-500 mt-1">Gerencie as informações e permissões de acesso.</p>
    </div>

    <form asp-controller="Usuario" asp-action="Editar" method="post" class="space-y-6">

        <div class="bg-white shadow-md rounded-lg p-6 border border-gray-100">
            <h3 class="text-lg font-semibold text-gray-700 mb-4 border-l-4 border-indigo-500 pl-3">Informações Básicas</h3>

            <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                <div>
                    <label for="nome" class="block text-sm font-medium text-gray-700 mb-1">Nome</label>
                    <input id="nome"
                           class="w-full rounded-md border border-gray-300 px-3 py-2 text-gray-900 placeholder-gray-400 focus:border-indigo-500 focus:outline-none focus:ring-1 focus:ring-indigo-500 sm:text-sm"
                           type="text"
                           name="Nome"
                           value="@Model.Nome"
                           placeholder="Digite o nome">
                </div>

                <div>
                    <label for="email" class="block text-sm font-medium text-gray-700 mb-1">Email</label>
                    <input id="email"
                           class="w-full rounded-md border border-gray-300 px-3 py-2 text-gray-900 placeholder-gray-400 focus:border-indigo-500 focus:outline-none focus:ring-1 focus:ring-indigo-500 sm:text-sm"
                           type="email"
                           name="Email"
                           value="@Model.Email"
                           placeholder="Digite o email">
                </div>
            </div>
        </div>

        <div class="bg-white shadow-md rounded-lg overflow-hidden border border-gray-100">
            <div class="px-6 py-4 bg-gray-50 border-b border-gray-200">
                <h5 class="text-lg font-semibold text-gray-800">Permissões do Usuário</h5>
            </div>

            <div class="p-6">
                <div class="grid grid-cols-1 lg:grid-cols-2 gap-8">

                    <div class="border rounded-lg overflow-hidden">
                        <div class="bg-indigo-50 px-4 py-2 border-b border-indigo-100">
                            <span class="text-sm font-bold text-indigo-700">Permissões Atuais</span>
                        </div>
                        <table class="min-w-full divide-y divide-gray-200" id="tblComPermissao">
                            <thead class="bg-gray-50">
                                <tr>
                                    <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Permissão</th>
                                    <th scope="col" class="px-6 py-3 text-right text-xs font-medium text-gray-500 uppercase tracking-wider">Ação</th>
                                </tr>
                            </thead>
                            <tbody class="bg-white divide-y divide-gray-200">
                                @if (Model.UsuarioPermissoes != null)
                                {
                                    foreach (var permissao in Model.UsuarioPermissoes)
                                    {
                                        <tr class="hover:bg-gray-50 transition-colors">
                                            <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-900">@permissao.Name</td>
                                            <td class="px-6 py-4 whitespace-nowrap text-right text-sm font-medium">
                                                <button type="button"
                                                        class="remove-btn inline-flex items-center px-3 py-1 border border-red-300 text-xs font-medium rounded text-red-700 bg-white hover:bg-red-50 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-red-500 transition-colors"
                                                        data-id="@permissao.Id">
                                                    Remover
                                                </button>
                                            </td>
                                        </tr>
                                    }
                                }
                            </tbody>
                        </table>
                    </div>

                    <div class="border rounded-lg overflow-hidden">
                        <div class="bg-gray-100 px-4 py-2 border-b border-gray-200">
                            <span class="text-sm font-bold text-gray-600">Disponíveis para Adicionar</span>
                        </div>
                        <table class="min-w-full divide-y divide-gray-200" id="tblSemPermissao">
                            <thead class="bg-gray-50">
                                <tr>
                                    <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Permissão</th>
                                    <th scope="col" class="px-6 py-3 text-right text-xs font-medium text-gray-500 uppercase tracking-wider">Ação</th>
                                </tr>
                            </thead>
                            <tbody class="bg-white divide-y divide-gray-200">
                                @foreach (var permissao in ViewBag.Permissoes)
                                {
                                    <tr class="hover:bg-gray-50 transition-colors">
                                        <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-900">@permissao.Name</td>
                                        <td class="px-6 py-4 whitespace-nowrap text-right text-sm font-medium">
                                            <button type="button"
                                                    class="add-btn inline-flex items-center px-3 py-1 border border-green-300 text-xs font-medium rounded text-green-700 bg-white hover:bg-green-50 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-green-500 transition-colors"
                                                    data-id="@permissao.Id">
                                                Adicionar
                                            </button>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>

                </div>
            </div>
        </div>

        <div class="flex justify-end space-x-3 pt-4">
            <a asp-action="Index" asp-controller="Usuario"
               class="px-4 py-2 bg-white border border-gray-300 rounded-md shadow-sm text-sm font-medium text-gray-700 hover:bg-gray-50 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-indigo-500">
                Cancelar
            </a>
            <button type="submit"
                    class="px-4 py-2 bg-indigo-600 border border-transparent rounded-md shadow-sm text-sm font-medium text-white hover:bg-indigo-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-indigo-500">
                Salvar Alterações
            </button>
        </div>
    </form>
</div>

<script>
    $(document).ready(function () {
        // Classes Tailwind para os estados dos botões
        const btnRemoveClasses = "remove-btn border-red-300 text-red-700 hover:bg-red-50 focus:ring-red-500";
        const btnAddClasses    = "add-btn border-green-300 text-green-700 hover:bg-green-50 focus:ring-green-500";

        // Remover permissão (Mover da esquerda para a direita)
        $(document).on("click", ".remove-btn", function () {
            var linha = $(this).closest("tr");
            var botao = $(this);

            // Troca visual do botão para "Adicionar"
            botao.removeClass(btnRemoveClasses)
                 .addClass(btnAddClasses)
                 .text("Adicionar");

            // Move para a tabela de disponíveis
            $("#tblSemPermissao tbody").append(linha);
        });

        // Adicionar permissão (Mover da direita para a esquerda)
        $(document).on("click", ".add-btn", function () {
            var linha = $(this).closest("tr");
            var botao = $(this);

            // Troca visual do botão para "Remover"
            botao.removeClass(btnAddClasses)
                 .addClass(btnRemoveClasses)
                 .text("Remover");

            // Move para a tabela de permissões atuais
            $("#tblComPermissao tbody").append(linha);
        });
    });
</script>