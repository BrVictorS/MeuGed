@model SGD.Models.ViewModels.PreparoViewModel

<div class="container mt-4">
    <div class="card shadow-sm mb-4">
        <div class="card-header">
            <h5 class="mb-0">Preparo</h5>
        </div>
        <div class="card-body">
            <form id="formLotes" method="post" action="/Preparo/SalvarPreparo">
                <input type="hidden" name="jsonLotes" id="jsonLotes" />

                <div class="row g-3 align-items-end">
                    <div class="col-md-5">
                        <label for="idlote" class="form-label">Lote</label>
                        <input type="text" class="form-control" id="idlote" placeholder="Digite o número do lote" />
                    </div>

                    <div class="col-md-5">
                        <label for="idUsuario" class="form-label">Usuário</label>
                        <select id="idUsuario" class="form-select">
                            <option value="" selected disabled>Selecione um usuário...</option>
                            @foreach (var usuario in Model.Usuarios)
                            {
                                <option value="@usuario.Id">@usuario.Nome</option>
                            }
                        </select>
                    </div>

                    <div class="col-md-2 d-grid">
                        <button type="button" class="btn btn-primary" id="btnAdicionar">
                            <i class="bi bi-plus-circle"></i> Adicionar
                        </button>
                    </div>
                </div>

                <hr />
                <div class="text-end">
                    <button type="submit" class="btn btn-success btn-lg">
                        <i class="bi bi-save"></i> Salvar Preparo
                    </button>
                </div>
            </form>
        </div>
    </div>

    <div class="card shadow-sm">
        <div class="card-header">
            <h5 class="mb-0">Lotes Adicionados</h5>
        </div>
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover table-striped mb-0" id="tabelaLotes">
                    <thead class="table-light">
                        <tr>
                            <th scope="col">Lote</th>
                            <th scope="col">Operador</th>
                            <th scope="col" class="text-center">Ações</th>
                        </tr>
                    </thead>
                    <tbody id="lotesBody">
                        <tr id="emptyRow">
                            <td colspan="3" class="text-center text-muted">Nenhum lote adicionado.</td>
                        </tr>
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

<style>
    /* Define uma altura máxima para o corpo da tabela e
          habilita o scroll vertical.
        */
    #lotesBody {
        display: block; /* Essencial para o scroll no tbody */
        max-height: 400px;
        overflow-y: auto;
    }

    /* Força o cabeçalho e as linhas do corpo a terem
          o mesmo layout de tabela para alinhar as colunas.
        */
    #tabelaLotes thead, #tabelaLotes tbody tr {
        display: table;
        width: 100%;
        table-layout: fixed;
    }

    /* Ajusta o tamanho da coluna de ações */
    #tabelaLotes th:nth-child(3),
    #tabelaLotes td:nth-child(3) {
        width: 120px; /* Largura fixa para a coluna de Ações */
    }
</style>

<script>
    // Espera o DOM carregar antes de executar o script
    document.addEventListener('DOMContentLoaded', function () {

        // 1. Armazena os elementos principais em cache
        const formLotes = document.getElementById('formLotes');
        const inputLote = document.getElementById('idlote');
        const selectUsuario = document.getElementById('idUsuario');
        const btnAdicionar = document.getElementById('btnAdicionar');
        const lotesBody = document.getElementById('lotesBody');
        const emptyRow = document.getElementById('emptyRow');
        
        const hiddenJsonLotes = document.getElementById('jsonLotes');

        // 2. Lógica para "Adicionar"
        btnAdicionar.addEventListener('click', function () {
            const lote = inputLote.value.trim();
            const idUsuario = selectUsuario.value;
            const nomeUsuario = selectUsuario.options[selectUsuario.selectedIndex].text;

            // Validação
            if (!lote || !idUsuario) {
                showMensagem("Por favor, preencha o lote e selecione um usuário.",true;
                return;
            }            

            // Remove a linha "vazio" se ela existir
            if (emptyRow) {
                emptyRow.remove();
            }

            // Cria a nova linha
            const novaLinha = document.createElement('tr');
            // Armazena os dados na própria linha
            novaLinha.setAttribute('data-id-usuario', idUsuario);
            novaLinha.setAttribute('data-lote', lote);

            novaLinha.innerHTML = `
                <td>${lote.toString().padStart(6, '0')}</td>
                <td>${nomeUsuario}</td>
                <td class="text-center">
                    <button type="button" class="btn btn-outline-danger btn-sm btn-remover">
                        <i class="bi bi-trash"></i>
                    </button>
                </td>
            `;
            
            lotesBody.appendChild(novaLinha);

            // Limpa os campos
            inputLote.value = '';
            selectUsuario.value = '';
            inputLote.focus(); // Foca no campo lote para o próximo
        });

        // 3. Lógica para "Remover" (Usando Delegação de Evento)
        // Ouve cliques no <tbody>, mas só reage se o clique foi
        // em um botão com a classe .btn-remover
        lotesBody.addEventListener('click', function (e) {
            // .closest() encontra o ancestral mais próximo que bate com o seletor
            const removeButton = e.target.closest('.btn-remover');

            if (removeButton) {
                removeButton.closest('tr').remove(); // Remove a linha (tr)
            }
        });

        // 4. Lógica para "Salvar" (Submit do Formulário)
        formLotes.addEventListener('submit', function (e) {
            // Seleciona APENAS as linhas de dados (dentro do tbody)
            const linhas = lotesBody.querySelectorAll('tr');
            const dados = [];

            linhas.forEach(linha => {
                // Pega os dados armazenados na linha
                const numeroLote = linha.getAttribute('data-lote');
                const idUsuario = linha.getAttribute('data-id-usuario');

                if (numeroLote && idUsuario) {
                    dados.push({
                        NumeroLote: numeroLote,
                        IdUsuario: parseInt(idUsuario, 10) // 10 = base decimal
                    });
                }
            });

            if (dados.length === 0) {
                e.preventDefault(); // Impede o envio do formulário
                showMensagem("Adicione pelo menos um lote antes de salvar.",true;
                return;
            }

            // Coloca o JSON no campo oculto para envio
            hiddenJsonLotes.value = JSON.stringify(dados);
        });
    });
</script>