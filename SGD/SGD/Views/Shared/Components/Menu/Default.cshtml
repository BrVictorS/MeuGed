@model UsuarioModel
@using Microsoft.AspNetCore.Http

<div class="flex flex-col w-full h-full bg-[#34495e] text-gray-100 shadow-xl">

    <div class="flex-shrink-0">
        <a class="block px-6 py-6 text-center text-lg font-bold tracking-wide text-white bg-black/10 hover:bg-black/20 transition-colors duration-200"
           asp-area="" asp-controller="Home" asp-action="Index">
            @(ViewContext.HttpContext.Session.GetString("nomeProjeto") ?? "SGD System")
        </a>
    </div>

    <nav class="flex-1 overflow-y-auto px-3 py-4 space-y-1">
        @if (Model != null)
        {
            <a class="group flex items-center gap-3 px-3 py-2.5 text-sm font-medium rounded-md transition-all duration-200 hover:bg-white/10 hover:text-white text-gray-300"
               asp-area="" asp-controller="Projeto" asp-action="Index">
                <i class="fa-solid fa-house w-6 text-center text-gray-400 group-hover:text-white transition-colors"></i>
                <span>Projetos</span>
            </a>

            <a class="group flex items-center gap-3 px-3 py-2.5 text-sm font-medium rounded-md transition-all duration-200 hover:bg-white/10 hover:text-white text-gray-300"
               asp-area="" asp-controller="Usuario" asp-action="Index">
                <i class="fa-solid fa-user w-6 text-center text-gray-400 group-hover:text-white transition-colors"></i>
                <span>Usuários</span>
            </a>

            <a class="group flex items-center gap-3 px-3 py-2.5 text-sm font-medium rounded-md transition-all duration-200 hover:bg-white/10 hover:text-white text-gray-300"
               asp-area="" asp-controller="Gestao" asp-action="Index">
                <i class="fa-solid fa-ticket w-6 text-center text-gray-400 group-hover:text-white transition-colors"></i>
                <span>Gestão</span>
            </a>

            <a class="group flex items-center gap-3 px-3 py-2.5 text-sm font-medium rounded-md transition-all duration-200 hover:bg-white/10 hover:text-white text-gray-300"
               asp-area="" asp-controller="Preparo" asp-action="Index">
                <i class="fa-solid fa-paperclip w-6 text-center text-gray-400 group-hover:text-white transition-colors"></i>
                <span>Preparo</span>
            </a>

            <a class="group flex items-center gap-3 px-3 py-2.5 text-sm font-medium rounded-md transition-all duration-200 hover:bg-white/10 hover:text-white text-gray-300"
               asp-area="" asp-controller="Scan" asp-action="Index">
                <i class="fa-solid fa-paper-plane w-6 text-center text-gray-400 group-hover:text-white transition-colors"></i>
                <span>Scan</span>
            </a>

            <a class="group flex items-center gap-3 px-3 py-2.5 text-sm font-medium rounded-md transition-all duration-200 hover:bg-white/10 hover:text-white text-gray-300"
               asp-controller="AutoImport" asp-action="Index">
                <i class="fa-solid fa-download w-6 text-center text-gray-400 group-hover:text-white transition-colors"></i>
                <span>Importar</span>
            </a>

            <a class="group flex items-center gap-3 px-3 py-2.5 text-sm font-medium rounded-md transition-all duration-200 hover:bg-white/10 hover:text-white text-gray-300"
               asp-area="" asp-route-fila="5" asp-controller="SelecionarLote" asp-action="Index">
                <i class="fa-solid fa-check w-6 text-center text-gray-400 group-hover:text-white transition-colors"></i>
                <span>Verificação</span>
            </a>

            <a class="group flex items-center gap-3 px-3 py-2.5 text-sm font-medium rounded-md transition-all duration-200 hover:bg-white/10 hover:text-white text-gray-300"
               asp-area="" asp-route-fila="6" asp-controller="SelecionarLote" asp-action="Index">
                <i class="fa-solid fa-box-archive w-6 text-center text-gray-400 group-hover:text-white transition-colors"></i>
                <span>Indexação</span>
            </a>

            <a class="group flex items-center gap-3 px-3 py-2.5 text-sm font-medium rounded-md transition-all duration-200 hover:bg-white/10 hover:text-white text-gray-300"
               asp-area="" asp-route-fila="6" asp-controller="SelecionarLote" asp-action="Index">
                <i class="fa-solid fa-file-export w-6 text-center text-gray-400 group-hover:text-white transition-colors"></i>
                <span>Exportação</span>
            </a>
        }
    </nav>

    <div class="flex-shrink-0 p-4 border-t border-white/10 bg-black/5">
        @if (Model != null)
        {
            <a class="flex items-center justify-center gap-2 w-full px-4 py-2 text-sm font-semibold text-red-200 transition-all duration-200 bg-red-900/30 border border-red-500/30 rounded-lg hover:bg-red-600 hover:text-white hover:border-transparent shadow-sm"
               asp-area="" asp-controller="Home" asp-action="Sair">
                <i class="fa-solid fa-arrow-right-from-bracket"></i>
                <span>Sair</span>
            </a>
        }
    </div>
</div>