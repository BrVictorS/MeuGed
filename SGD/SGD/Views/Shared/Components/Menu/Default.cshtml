@model UsuarioModel
@using Microsoft.AspNetCore.Http
<a class="navbar-brand  " asp-area="" asp-controller="Home" asp-action="Index">@ViewContext.HttpContext.Session.GetString("nomeProjeto")</a>
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - SGD</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <style>
        /* CSS para a barra lateral vertical */


        .sidebar-nav {
            position: fixed;
            top: 0;
            left: 0;
            height: 100vh;
            width: 200px;            
            border-right: 1px solid #dee2e6;
            padding-top: 1rem;
            display: flex;
            flex-direction: column; /* Exibe os itens verticalmente */
            align-items: flex-start; /* Alinha os itens à esquerda */
            background-color: #34495e;
            justify-content: flex-start; /* Garante que os itens comecem no topo */
        }

        .sidebar-nav .navbar-brand {
            width: 100%;
            text-align: center; /* Centraliza o navbar-brand */
            padding: 1rem 0; /* Espaçamento vertical */

        }

        .sidebar-nav .navbar-nav {
            display: flex;
            flex-direction: column; /* Exibe os itens de navegação em coluna */
        }

        .sidebar-nav .nav-item {
            width: 100%; /* Cada botão/ link ocupará toda a largura da barra */
        }
        
        .dropdown{
            padding-left:10px;
        }

        .btnome{
            color:white;
            text-decoration: none;
        }

        .nav-links-color {
            
            width: 100%;
            padding: 0.5rem 0;
        }

        .nav-links-color .nav-link {
            color: white;            
        }

        .nav-links-color .nav-link:hover {
            background-color: #2c3e50;
            color: #ecf0f1;
        }

        .main-content {
            margin-left: 200px; /* Mesma largura da sidebar */
            padding: 1rem;
        }

        hr {
            border:none;
            height: 2px;
            background-color: white; /* sua cor personalizada */
        }

    </style>
</head>


<div class="d-flex flex-column bg-body-tertiary" style="width:200px">
    <hr />
    <div class="dropdown" asp-for="model">
        <a href="#" class=" btnome d-flex align-items-center dropdown-toggle" data-bs-toggle="dropdown" aria-expanded="false">
            <img src="https://github.com/mdo.png" alt="" width="32" height="32" class="rounded-circle me-2">
            <strong>@Model.Nome</strong>
        </a>

        <ul class="dropdown-menu text-small shadow" style="">
            <li>
                <a class="dropdown-item" href="#">New project...</a>
            </li>

            <li>
                <a class="dropdown-item" href="#">Settings</a>
            </li>

            <li>
                <a class="dropdown-item" href="#">Profile</a>
            </li>

            <li>
                <hr class="dropdown-divider">
            </li>

            <li>
                <a class="dropdown-item" href="#">Sign out</a>
            </li>
        </ul>
    </div>
    <hr />
   

    <div class="nav-links-color">
        @if (Model != null)
        {            
            
            <a class="nav-link link-body-emphasis" asp-area="" asp-controller="Projeto" asp-action="Index">
                <i class="bi bi-house"></i> 
                Projetos</a>
            <a class="nav-link link-body-emphasis" asp-area="" asp-controller="Usuario" asp-action="Index"><i class="bi bi-people"></i> Usuários</a>
            <a class="nav-link link-body-emphasis" asp-area="" asp-controller="Gestao" asp-action="Index"><i class="bi bi-ticket-fill"></i> Gestão</a>

            <a class="nav-link link-body-emphasis" asp-area="" asp-controller="Preparo" asp-action="Index">
                <i class="bi bi-printer"></i>
                Preparo
            </a>

            <a class="nav-link link-body-emphasis" asp-area="" asp-controller="Scan" asp-action="Index">
                <i class="bi bi-send"></i>
                Scan
            </a>

            <a class="nav-link link-body-emphasis" asp-controller="AutoImport" asp-action="Index">
                <i class="bi bi-download"></i>
                Importar
            </a>


            <a class="nav-link link-body-emphasis" asp-area="" asp-route-fila="5"  asp-controller="SelecionarLote" asp-action="Index">
                <i class="bi bi-check2"></i>
                Verificação
            </a>

            <a class="nav-link link-body-emphasis" asp-area="" asp-route-fila="6" asp-controller="SelecionarLote" asp-action="Index">
                <i class="bi bi-file-earmark-medical"></i>
                Indexação
            </a>

            <a class="nav-link link-body-emphasis" asp-area="" asp-route-fila="6" asp-controller="SelecionarLote" asp-action="Index">
                <i class="bi bi-file-earmark-pdf"></i>
                Exportação
            </a>
            
            <hr />
            <a class="nav-link mt-auto link-body-emphasis btnsair" asp-area="" asp-controller="Home" asp-action="Sair"><i class="bi bi-box-arrow-in-left"></i> Sair</a>
        }
    </div>       
</div>

