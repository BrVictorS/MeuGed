@using Microsoft.AspNetCore.Http
@using System.Security.Claims
@using SGD.Dtos.Response
@using System.Text.Json

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - SGD</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/SGD.styles.css" asp-append-version="true" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.13.1/font/bootstrap-icons.min.css">
    <style>
        .main-content {
            margin-left: 0px; /* Mesma largura da sidebar */            
        } 

        .main-content2 {
            margin-left: 200px; /* Mesma largura da sidebar */
        }

        .navhead{
            margin-left:200px;
            background-color:#0070CC;
            color:white;
        }

        .alerts-overlay {
            position: fixed;
            top: 20px;
            left: 50%;
            transform: translateX(-50%);
        }

            .alerts-overlay .alert {
                pointer-events: auto; /* permite clicar no X, links etc. */
                opacity: 1;
                transition: opacity .35s ease;
            }

            .alerts-overlay.hide .alert {
                opacity: 0;
            }
    </style>
</head>
<body>
    <header>  
        
        @if (User.FindFirst(ClaimTypes.NameIdentifier)?.Value != null && !string.IsNullOrEmpty(ViewContext.HttpContext.Session.GetString("idProjeto")))
        {
           
            <nav class="navbar sidebar-nav navbar-dark ">
                @await Component.InvokeAsync("Menu")
            </nav>
        }
    </header>

    <div class="@(User.FindFirst(ClaimTypes.NameIdentifier)?.Value != null && !string.IsNullOrEmpty(ViewContext.HttpContext.Session.GetString("idProjeto")) ? " container-fluid main-content" : "container-fluid main-content" )" style="@(!string.IsNullOrEmpty(ViewContext.HttpContext.Session.GetString("idProjeto")) ? "width: 89%" : "")">
        <main role="main" class="pb-3">
            <div id="alerts" class="alerts-overlay">
                @await Html.PartialAsync("_Alerts")
            </div>
            <div id="erro" class="alerts-overlay">
                @await Html.PartialAsync("_ErroAlert")
            </div>
            @RenderBody()
        </main>

    </div>


   @*  <footer class="border-top footer text-muted main-content">
        <div class="container">
            &copy; 2024 - SGD - <a asp-area="" asp-controller="Home" asp-action="Privacy">Privacy</a>
        </div>
    </footer> *@
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
    <script>
        document.addEventListener('DOMContentLoaded', () => {
            const box = document.getElementById('alerts');
            const html = box.innerHTML.trim();
            if (html) showAlert(html);   // chama seu showAlert apenas uma vez
        });

        function showAlert(html) {
            const box = document.getElementById('alerts');
            if (!html || !html.trim()) return;     // não exibe nada se vier vazio
            box.innerHTML = html;
            box.classList.remove('hide');
            box.style.display = 'block';

            // limpa timer anterior para não empilhar
            clearTimeout(box._timer);
            box._timer = setTimeout(() => {
                box.classList.add('hide');           // inicia fade
                setTimeout(() => {                   // remove após o fade
                    box.style.display = 'none';
                    box.innerHTML = '';
                }, 400);
            }, 5000);                              // 5s
        }

        function showMensagem(msg, tipo = "erro") {
            const box = document.getElementById('mensagem');
            if (!msg || !msg.trim()) return;

            // limpa classes anteriores
            box.className = "";

            // aplica estilo conforme tipo
            if (tipo === "sucesso") {
                box.classList.add('alert', 'alert-success');
            } else {
                box.classList.add('alert', 'alert-danger');
            }

            box.innerHTML = msg;
            box.style.display = 'block';

            clearTimeout(box._timer);
            box._timer = setTimeout(() => {
                box.classList.add('hide');
                setTimeout(() => {
                    box.style.display = 'none';
                    box.innerHTML = '';
                    box.className = "";
                }, 400);
            }, 5000);
        }
        
    </script>
</body>
</html>
