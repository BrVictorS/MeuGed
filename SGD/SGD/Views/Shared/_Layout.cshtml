@using Microsoft.AspNetCore.Http
@using System.Security.Claims
@using SGD.Dtos.Response
@using System.Text.Json

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - SGD</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/SGD.styles.css" asp-append-version="true" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.13.1/font/bootstrap-icons.min.css">
    <style>
        .body{
            
        }
        .main-content {
            margin-left: 0px; /* Mesma largura da sidebar */   
            background-color: rgb(237, 237, 237);
            height:100vh;
        } 

        .main-content2 {
            margin-left: 200px; /* Mesma largura da sidebar */
            background-color: rgb(237, 237, 237);
        }

        .navhead{
            margin-left:200px;
            background-color:#0070CC;
            color:white;
        }

        .alerts-overlay {
            position: fixed;
            top: 20px;
            left: 50%;            
            transform: translateX(-50%);
        }

            .alerts-overlay {
                pointer-events: auto; /* permite clicar no X, links etc. */
                opacity: 1;
                transition: opacity .35s ease;
            }

            .alerts-overlay.hide {
                opacity: 0;
            }
    </style>
</head>
<body>
    <header>  
        
        @if (User.FindFirst(ClaimTypes.NameIdentifier)?.Value != null && !string.IsNullOrEmpty(ViewContext.HttpContext.Session.GetString("idProjeto")))
        {
           
            <nav class="navbar sidebar-nav navbar-dark ">
                @await Component.InvokeAsync("Menu")
            </nav>
        }
    </header>

    <div class="@(User.FindFirst(ClaimTypes.NameIdentifier)?.Value != null && !string.IsNullOrEmpty(ViewContext.HttpContext.Session.GetString("idProjeto")) ? " container-fluid main-content" : "container-fluid main-content" )" style="@(!string.IsNullOrEmpty(ViewContext.HttpContext.Session.GetString("idProjeto")) ? "width: 89%" : "")">
        <main role="main" class="pb-3 principal">
            <div id="alerts" class="alerts-overlay">
                @await Html.PartialAsync("_Alerts")
            </div>
            @RenderBody()
        </main>

    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)



    <script>
        document.addEventListener('DOMContentLoaded', () => {
            const box = document.getElementById('alerts');
            const html = box.innerHTML.trim();            
        });

        function showMensagem(msg,tipo) {
            const box = document.getElementById('alerts');

            box.className = "";            
            box.classList.add('alert');
            //box.classList.add('alerts-overlay');

            if(tipo !== undefined){
                if (!tipo) 
                {
                     box.classList.add('alert-success');
                }else{
                    box.classList.add('alert-danger');
                }
            }
            else 
            {
                box.classList.add('alert-danger');
            }
                        
            box.style.position = 'fixed';
            box.style.left = '50%';

            box.innerHTML = `<div>${msg}</div>`;
            box.style.display = 'block';

            clearTimeout(box._timer);
            box._timer = setTimeout(() => {
                box.classList.add('hide');
                setTimeout(() => {
                    box.style.display = 'none';
                    box.innerHTML = '';
                    box.className = "";
                }, 400);
            }, 5000);
        }
        
    </script>
</body>
</html>
