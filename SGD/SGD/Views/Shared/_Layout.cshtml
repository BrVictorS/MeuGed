@using Microsoft.AspNetCore.Http
@using System.Security.Claims
@using SGD.Dtos.Response
@using System.Text.Json

<!DOCTYPE html>
<html lang="pt-br">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - SGD</title>

    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Cal+Sans&family=Nunito+Sans:ital,opsz,wght@0,6..12,200..1000;1,6..12,200..1000&display=swap" rel="stylesheet">
    
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">

    <script src="https://cdn.tailwindcss.com"></script>
    <script>
        tailwind.config = {
            theme: {
                extend: {
                    fontFamily: {
                        sans: ['"Nunito Sans"', 'sans-serif'],
                    },
                    colors: {
                        brand: {
                            blue: '#0070CC',
                        }
                    }
                }
            }
        }
    </script>
</head>
<body class="bg-[#EDEDED] font-sans text-gray-800 h-screen overflow-hidden flex flex-col">

    <div class="flex flex-1 h-full overflow-hidden">

        @{
            var userLogged = User.FindFirst(ClaimTypes.NameIdentifier)?.Value != null;
            var projectSelected = !string.IsNullOrEmpty(ViewContext.HttpContext.Session.GetString("idProjeto"));
        }

        @* @/* Lógica da Sidebar: Só exibe se logado e com projeto selecionado */ *@
        @if (userLogged && projectSelected)
        {
            <aside class="no-print w-64 bg-white border-r border-gray-200 hidden md:flex flex-col shadow-sm z-20 h-full overflow-y-auto">
                @await Component.InvokeAsync("Menu")
            </aside>
        }

        <main role="main" class="flex-1 relative overflow-y-auto overflow-x-hidden" id="main-container">
            
            <div id="alerts" class="no-print pointer-events-none fixed top-5 left-1/2 -translate-x-1/2 z-50 flex flex-col gap-2 w-auto min-w-[300px] max-w-md transition-all duration-300 opacity-0">
                @await Html.PartialAsync("_Alerts")
            </div>

            @RenderBody()
        </main>
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    <script src="/_sdk/data_sdk.js" type="text/javascript"></script>
    <script src="/_sdk/element_sdk.js" type="text/javascript"></script>

    @await RenderSectionAsync("Scripts", required: false)

    <script>
        document.addEventListener('DOMContentLoaded', () => {
            // Verifica se já existe html injetado pelo servidor nos alertas e exibe
            const box = document.getElementById('alerts');
            if(box.innerHTML.trim().length > 0) {
                 box.classList.remove('opacity-0');
                 box.classList.add('opacity-100');
            }
        });

        /* Função Refatorada para Tailwind 
           tipo: false/undefined = Erro (Vermelho)
           tipo: true = Sucesso (Verde)
           (A lógica original usava !tipo para sucesso, mantive essa lógica inversa para compatibilidade)
        */
        function showMensagem(msg, tipo) {
            const box = document.getElementById('alerts');
            
            // Reseta classes de visibilidade
            box.style.display = 'flex';
            box.innerHTML = ''; 

            // Cria o elemento do alerta
            const alertDiv = document.createElement('div');
            
            // Classes base do alerta (Padding, bordas, sombra, alinhamento)
            let classes = "pointer-events-auto px-4 py-3 rounded shadow-lg text-white font-medium flex items-center justify-between mx-auto w-full transition-all transform duration-300";

            // Lógica de Cores baseada no parâmetro 'tipo'
            // O código original tratava (tipo === undefined) como erro
            // E (!tipo) como sucesso. 
            if (tipo !== undefined && !tipo) {
                // Sucesso (Verde)
                classes += " bg-green-600";
            } else {
                // Erro (Vermelho/Brand)
                classes += " bg-red-600";
            }

            alertDiv.className = classes;
            alertDiv.innerHTML = `<span>${msg}</span>`;

            // Adiciona ao container
            box.appendChild(alertDiv);

            // Animação de entrada
            requestAnimationFrame(() => {
                box.classList.remove('opacity-0');
                box.classList.add('opacity-100');
            });

            // Timer para remover
            clearTimeout(box._timer);
            box._timer = setTimeout(() => {
                // Animação de saída
                box.classList.remove('opacity-100');
                box.classList.add('opacity-0');

                setTimeout(() => {
                    box.innerHTML = '';
                    box.style.display = 'none';
                }, 300); // Espera a transição CSS terminar
            }, 5000);
        }
    </script>
</body>
</html>