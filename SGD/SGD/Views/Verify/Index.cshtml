@using SGD.Dtos.Lote
@model LoteApiDto

<div class="flex h-screen w-full bg-gray-100 overflow-hidden font-sans">

    <input id="idlote" type="hidden" value="@Model.idLote" />
    <input id="ilote" hidden value="@Model.idLote" />

    <div class="w-96 flex-shrink-0 bg-white border-r border-gray-200 flex flex-col shadow-lg z-10">
        <div class="p-4 bg-gray-50 border-b border-gray-200 flex justify-between items-center">
            <div>
                <h2 class="text-sm font-bold text-gray-700 uppercase tracking-wider">Imagens do Lote</h2>
                <p class="text-xs text-gray-500">Arraste para reordenar</p>
            </div>
            <span class="bg-blue-100 text-blue-800 text-xs font-semibold px-2.5 py-0.5 rounded">
                @Model.imagens.Count()
            </span>
        </div>

        <div class="flex-1 overflow-y-auto custom-scrollbar">
            <table class="w-full text-sm text-left" id="tabelaImagens">
                <thead class="text-xs text-gray-500 uppercase bg-gray-50 sticky top-0 z-10 shadow-sm">
                    <tr>
                        <th scope="col" class="px-4 py-3 w-12 text-center">Doc</th>
                        <th scope="col" class="px-4 py-3">Arquivo</th>
                        <th scope="col" class="px-4 py-3 text-right">Situação</th>
                    </tr>
                </thead>
                <tbody id="tableBody" class="divide-y divide-gray-100">
                    @foreach (var imagem in Model.imagens)
                    {
                        // Definição de cores baseada na situação (Lógica visual)
                        string rowClass = "hover:bg-blue-50 transition-colors cursor-move group";
                        string statusColor = "text-gray-500";

                        if (imagem.situacao == "OK") { statusColor = "text-green-600 font-bold"; }
                        else if (imagem.situacao == "RUIM") { rowClass += " bg-red-50 hover:bg-red-100"; statusColor = "text-red-600 font-bold"; }

                        <tr class="@rowClass table-row"
                            draggable="true"
                            data-img="@imagem.id"
                            data-img-st="@imagem.situacao"
                            data-doc="@imagem.documentoId"
                            onclick="selecionarLinha(this, '@imagem.caminho')">
                            <td class="px-4 py-3 text-center font-mono text-gray-600">
                                @imagem.documentoId
                            </td>
                            <td class="px-4 py-3">
                                <div class="flex items-center gap-3">
                                    <i class="bi bi-grip-vertical text-gray-300 group-hover:text-gray-500"></i>
                                    <span class="truncate max-w-[120px]" title="@imagem.caminho">@imagem.caminho</span>
                                </div>
                            </td>
                            <td class="px-4 py-3 text-right @statusColor">
                                @imagem.situacao
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>

    <div class="flex-1 flex flex-col bg-slate-800 relative">

        <div id="viewport" class="flex-1 flex items-center justify-center overflow-hidden p-4 relative">
            <div id="empty-placeholder" class="text-center text-slate-500">
                <i class="bi bi-image text-6xl mb-2 opacity-50"></i>
                <p>Selecione uma imagem na lista</p>
            </div>

            <img id="previewImg" src="" alt="Pré-visualização" class="max-w-full max-h-full object-contain shadow-2xl hidden transition-transform duration-200">
        </div>

        <div class="absolute bottom-6 left-1/2 transform -translate-x-1/2 bg-white/90 backdrop-blur-md border border-gray-200 rounded-2xl shadow-2xl p-2 flex items-center gap-2 z-20">

            <button type="button" id="inseredoc" onclick="toggleModalDoc(true)"
                    class="flex items-center gap-2 px-4 py-2 text-sm font-medium text-gray-700 hover:bg-gray-100 rounded-xl transition-colors"
                    title="Inserir Documento">
                <i class="bi bi-file-earmark-plus text-blue-600 text-lg"></i>
                <span class="hidden md:inline">Novo Doc</span>
            </button>

            <div class="w-px h-6 bg-gray-300 mx-1"></div> <button type="button" id="btn-img-ruim"
                                                                  class="flex items-center gap-2 px-4 py-2 text-sm font-medium text-gray-700 hover:bg-red-50 hover:text-red-600 rounded-xl transition-colors"
                                                                  title="Marcar como Imagem Ruim">
                <i class="bi bi-exclamation-triangle text-lg"></i>
                <span class="hidden md:inline">Ruim</span>
            </button>

            <button type="button" class="flex items-center gap-2 px-4 py-2 text-sm font-medium text-gray-700 hover:bg-green-50 hover:text-green-600 rounded-xl transition-colors"
                    title="Definir como Planta">
                <i class="bi bi-diagram-3 text-lg"></i>
                <span class="hidden md:inline">Planta</span>
            </button>

            <div class="w-px h-6 bg-gray-300 mx-1"></div> <button id="btnAddTif" type="button" onclick="document.getElementById('fileTif').click()"
                                                                  class="flex items-center gap-2 px-4 py-2 text-sm font-medium text-gray-700 hover:bg-cyan-50 hover:text-cyan-600 rounded-xl transition-colors"
                                                                  title="Upload de Imagem">
                <i class="bi bi-upload text-lg"></i>
                <span class="hidden md:inline">Upload</span>
            </button>
            <input id="fileTif" type="file" accept=".tif,.tiff,image/tiff" multiple hidden>

            <a asp-action="FinalizaLote" class="ml-2">
                <button type="button" id="btnFinaliza"
                        class="flex items-center gap-2 px-6 py-2.5 bg-blue-600 hover:bg-blue-700 text-white text-sm font-bold rounded-xl shadow-lg hover:shadow-blue-500/30 transition-all transform hover:-translate-y-0.5">
                    <i class="bi bi-check2-circle text-lg"></i>
                    Finalizar
                </button>
            </a>
        </div>
    </div>
</div>

<div id="mdlDocumento" class="fixed inset-0 z-50 hidden" aria-labelledby="modal-title" role="dialog" aria-modal="true">
    <div class="fixed inset-0 bg-black/60 backdrop-blur-sm transition-opacity" onclick="toggleModalDoc(false)"></div>

    <div class="fixed inset-0 z-10 overflow-y-auto">
        <div class="flex min-h-full items-center justify-center p-4 text-center">
            <div class="relative transform overflow-hidden rounded-2xl bg-white text-left shadow-2xl transition-all w-full max-w-sm">

                <div class="bg-white px-6 py-6">
                    <div class="flex justify-between items-center mb-4">
                        <h3 class="text-lg font-bold text-gray-900">Inserir Documento</h3>
                        <button onclick="toggleModalDoc(false)" class="text-gray-400 hover:text-gray-600">
                            <i class="bi bi-x-lg"></i>
                        </button>
                    </div>

                    <div class="space-y-4">
                        <div>
                            <label for="docNumero" class="block text-sm font-medium text-gray-700 mb-1">Número do Documento</label>
                            <input id="docNumero" type="text" inputmode="numeric" maxlength="10"
                                   class="block w-full rounded-lg border-gray-300 border px-3 py-2 text-gray-900 shadow-sm focus:border-blue-500 focus:ring-blue-500 sm:text-lg font-mono placeholder-gray-300"
                                   placeholder="00000000">
                            <p id="docErro" class="mt-2 text-sm text-red-600 hidden flex items-center gap-1">
                                <i class="bi bi-info-circle-fill"></i> Informe entre 1 e 10 dígitos.
                            </p>
                        </div>
                    </div>
                </div>

                <div class="bg-gray-50 px-6 py-4 flex flex-row-reverse gap-2">
                    <button id="btnSalvarDoc" type="button" disabled
                            class="inline-flex w-full justify-center rounded-lg bg-blue-600 px-3 py-2 text-sm font-semibold text-white shadow-sm hover:bg-blue-500 disabled:opacity-50 disabled:cursor-not-allowed sm:w-auto transition-all">
                        Salvar
                    </button>
                    <button type="button" onclick="toggleModalDoc(false)"
                            class="inline-flex w-full justify-center rounded-lg bg-white px-3 py-2 text-sm font-semibold text-gray-900 shadow-sm ring-1 ring-inset ring-gray-300 hover:bg-gray-50 sm:w-auto transition-all">
                        Cancelar
                    </button>
                </div>
            </div>
        </div>
    </div>
</div>

<script src="~/js/verificacao.js" asp-append-version="true"></script>

<script>
    // Controle do Modal
    function toggleModalDoc(show) {
        const modal = document.getElementById('mdlDocumento');
        const input = document.getElementById('docNumero');
        const btnSalvar = document.getElementById('btnSalvarDoc');
        const erroMsg = document.getElementById('docErro');

        if (show) {
            modal.classList.remove('hidden');
            setTimeout(() => input.focus(), 100);
        } else {
            modal.classList.add('hidden');
            input.value = '';
            erroMsg.classList.add('hidden');
            btnSalvar.disabled = true;
        }
    }

    // Validação simples do input do modal
    document.getElementById('docNumero').addEventListener('input', function(e) {
        // Remove não números
        this.value = this.value.replace(/\D/g, '');

        const isValid = this.value.length > 0 && this.value.length <= 10;
        const btnSalvar = document.getElementById('btnSalvarDoc');
        const erroMsg = document.getElementById('docErro');

        btnSalvar.disabled = !isValid;

        if(this.value.length > 0 && !isValid) {
            erroMsg.classList.remove('hidden');
        } else {
            erroMsg.classList.add('hidden');
        }
    });

    // Função visual para selecionar linha e mostrar imagem
    // (Isso complementa o verificacao.js, não o substitui)
    function selecionarLinha(tr, caminhoImagem) {
        // 1. Remove seleção anterior
        document.querySelectorAll('#tableBody tr').forEach(row => {
            row.classList.remove('bg-blue-100', 'border-l-4', 'border-blue-500');
        });

        // 2. Adiciona seleção atual
        tr.classList.add('bg-blue-100', 'border-l-4', 'border-blue-500');

        // 3. Atualiza Preview
        const img = document.getElementById('previewImg');
        const placeholder = document.getElementById('empty-placeholder');

        // Simulação de caminho (ajuste conforme sua lógica real de rota de imagens)
        // Se o caminho já for uma URL completa, use-a. Se for apenas nome, precise de path.
        // Exemplo: /Imagens/LoteX/nome.tif

        // Aqui assumo que o verificacao.js faz o load real,
        // mas visualmente mostramos/escondemos o placeholder
        if(caminhoImagem) {
            placeholder.classList.add('hidden');
            img.classList.remove('hidden');
            // img.src = ... (O script verificacao.js deve cuidar disso)
        }
    }
</script>

<style>
    /* Scrollbar personalizada para Webkit */
    .custom-scrollbar::-webkit-scrollbar {
        width: 6px;
    }

    .custom-scrollbar::-webkit-scrollbar-track {
        background: #f1f1f1;
    }

    .custom-scrollbar::-webkit-scrollbar-thumb {
        background: #c1c1c1;
        border-radius: 3px;
    }

        .custom-scrollbar::-webkit-scrollbar-thumb:hover {
            background: #a8a8a8;
        }
</style>