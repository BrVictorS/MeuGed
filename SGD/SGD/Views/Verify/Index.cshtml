@using SGD.Dtos.Lote
@model LoteApiDto
<body>      
   <div class="app">
        <div class="dashboard-grid">
            <!-- Left Panel - Draggable Table -->
            <div class="panel-dados">
                <input id="idlote" type="hidden" value="@Model.idLote" />
                <div class="table-container">
                    <table class="data-table">
                        <thead class="table-header">
                            <tr>
                                <th></th>
                                <th></th>
                                <th></th>
                            </tr>
                        </thead>
                        <tbody id="tableBody">
                            @foreach (var imagem in Model.imagens)
                            {
                                <tr class="table-row"
                                    draggable="true"
                                    data-img="@imagem.id"
                                    data-img-st="@imagem.situacao"
                                    data-doc="@imagem.documentoId">
                                    <td>
                                        @imagem.documentoId
                                    </td>
                                    <td>
                                        <div class="drag-handle">
                                            <span class="grip-icon icon-grip"></span>
                                            <span>@imagem.caminho</span>
                                        </div>
                                    </td>
                                    <td>@imagem.situacao</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>

            <!-- Right Panel - Image Carousel -->
            <div class="panel-img" id="viewport">
                <img id="previewImg" src="" alt="Pré-visualização">
            </div>            
        </div>

        <div class="d-flex justify-content-between align-items-center my-3 flex-wrap w-100 px-3">
            <div class="btn-group shadow-sm rounded" role="group" aria-label="Ações do documento">
                <button type="button" class="btn btn-outline-secondary" id="inseredoc"
                        data-bs-toggle="modal" data-bs-target="#mdlDocumento">
                    <i class="bi bi-file-earmark-plus"></i> Inserir Documento
                </button>

                <button type="button" id="btn-img-ruim" class="btn btn-outline-warning">
                    <i class="bi bi-exclamation-triangle"></i> Imagem Ruim
                </button>

                <button type="button" class="btn btn-outline-success">
                    <i class="bi bi-diagram-3"></i> Planta
                </button>

                <button id="btnAddTif" type="button" class="btn btn-outline-info">
                    <i class="bi bi-plus-circle"> Inserir imagem</i>
                </button>
                <input id="fileTif" type="file" accept=".tif,.tiff,image/tiff" multiple hidden>

            </div>
            <a asp-action="FinalizaLote">
                <button type="button" id="btnFinaliza" class="btn btn-primary shadow-sm rounded px-4 mt-2 mt-md-0">
                <i class="bi bi-check2-circle"></i> Finalizar Lote
            </button>
            </a>
        </div>
        <input id="ilote" hidden value="@Model.idLote"/>
   </div>
    <!-- Modal -->
    <div class="modal fade" id="mdlDocumento" tabindex="-1" aria-hidden="true">
        <div class="modal-dialog modal-sm">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">Inserir documento</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body">
                    <label class="form-label">Número do documento</label>
                    <input id="docNumero" class="form-control" inputmode="numeric" maxlength="10" pattern="\d*">
                    <div id="docErro" class="text-danger mt-1" style="display:none;">Informe 1–10 dígitos.</div>
                </div>
                <div class="modal-footer">
                    <button id="btnSalvarDoc" type="button" class="btn btn-primary" disabled>Salvar</button>
                </div>
            </div>
        </div>
    </div>
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        .main {
            background-color: red;
        }

        html, body {
            height: 100%;
            margin: 0;
            padding: 0;
        }
        /* sem overflow:hidden */
        .app {
            display: grid;
            grid-template-rows: 1fr auto; /* conteúdo + barra fixa visível */
            height: 90vh;
        }

        .dashboard-grid {
            display: grid;
            grid-template-columns: 320px 200px; /* tabela fixa + painel que ocupa o resto */
            height: 90vh; /* ocupa altura exata da tela */
            width: 100vw; /* ocupa largura exata da tela */
        }
            .dashboard-grid > :nth-child(2n) {
                justify-self: start;
            }

        .dashboard-grid {
            display: grid;
            grid-template-columns: 320px 1fr;
            width: 100%; /* evita 100vw e barra horizontal */
            min-height: 0; /* permite rolagem interna */
        }

        .panel-img, .panel-dados {
            border-radius: 1rem;
            box-shadow: 0 10px 25px rgba(0,0,0,0.1);
            border: 1px solid #e5e7eb;
            overflow: auto;
            padding: 1rem;
        }

        .table-row.selected {
            background-color: #3b82f6; /* azul */
            color: white; /* opcional, para melhor contraste */
        }

        .image-ok {
            background-color: #00911e;
            color: white;
        }

        .image-del {
            background-color: #ff8945;
            color: white;
        }

        .image-ruim {
            background-color: red;
            color: white;
        }

        .panel-img {
            display: flex;
            align-items: center;
            justify-content: center;
            overflow: hidden; /* evita barras extras */
            background-color: gray;
        }

        #previewImg {
            max-width: 100%;
            max-height: 100%;
            height: auto;
            object-fit: contain;
            display: block;
        }

        /* Table Styles */
        .table-container {
            overflow: hidden;
            border-radius: 0.5rem;
            border: 1px solid #e5e7eb;
        }

        .data-table {
            width: 100%;
            border-collapse: collapse;
        }

        .table-header {
            background: linear-gradient(135deg, #2563eb 0%, #1d4ed8 100%);
        }

            .table-header th {
                padding: 1rem 1.5rem;
                text-align: left;
                font-size: 0.875rem;
                font-weight: 600;
                color: white;
                text-transform: uppercase;
                letter-spacing: 0.05em;
            }

        .table-row {
            cursor: move;
            transition: all 0.2s ease;
            border-bottom: 1px solid #e5e7eb;
        }

            .table-row:hover {
                background-color: #eff6ff;
            }

            .table-row.dragging {
                /* opacity: 0.5; */
                background-color: #dbeafe;
                transform: scale(1.02);
            }

            .table-row.drag-over {
                /* border-top: 3px solid #2563eb; */
            }

            .table-row td {
                padding: 1rem 1.5rem;
                white-space: nowrap;
            }

        .drag-handle {
            display: flex;
            align-items: center;
        }

        .grip-icon {
            width: 16px;
            height: 16px;
            margin-right: 0.75rem;
            color: #6b7280;
        }

        .table-hint {
            margin-top: 1rem;
            text-align: center;
            font-size: 0.75rem;
            color: #6b7280;
        }


        /* Icons using CSS */
        .icon-grip::before {
            content: "⋮⋮";
            font-weight: bold;
            letter-spacing: -2px;
        }

        .icon-chevron-left::before {
            content: "‹";
            font-size: 20px;
            font-weight: bold;
        }

        .icon-chevron-right::before {
            content: "›";
            font-size: 20px;
            font-weight: bold;
        }

        .icon-table::before {
            content: "⊞";
            font-size: 20px;
        }

        .icon-images::before {
            content: "🖼";
            font-size: 20px;
        }
    </style> 
</body>
<script src="~/js/verificacao.js" asp-append-version="true"></script>
