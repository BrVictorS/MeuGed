@using SGD.Dtos.TipoDocumento
@model TipoDocumentoDto

<div class="max-w-4xl mx-auto mt-10 px-4">

    <form method="post" asp-controller="TipoDocumento" asp-action="@(Model.Id > 0 ? "Editar" : "Novo")" id="mainForm">

        <div class="bg-white shadow-lg rounded-lg overflow-hidden border border-gray-100">
            <div class="bg-gray-50 px-6 py-4 border-b border-gray-200">
                <h2 class="text-xl font-bold text-gray-800">
                    @(Model.Id > 0 ? "Editar Tipo Documental" : "Novo Tipo Documental")
                </h2>
            </div>

            <div class="p-6 space-y-6">
                <input type="hidden" asp-for="Id" />

                <div>
                    <label asp-for="Name" class="block text-sm font-medium text-gray-700 mb-1">Título</label>
                    <input type="text" asp-for="Name"
                           class="w-full rounded-md border border-gray-300 px-3 py-2 text-gray-900 focus:border-blue-500 focus:ring-blue-500 sm:text-sm"
                           placeholder="Ex: Contrato, Fatura, Ofício...">
                    <span class="text-red-500 text-xs mt-1 hidden" id="validaNome">
                        <i class="bi bi-exclamation-circle"></i> O título deve ser preenchido!
                    </span>
                </div>

                <div>
                    <div class="flex justify-between items-center mb-4">
                        <h3 class="text-lg font-medium text-gray-700">Metadados Associados</h3>
                        <button type="button" onclick="toggleModal(true)"
                                class="inline-flex items-center px-3 py-1.5 border border-transparent text-sm font-medium rounded text-blue-700 bg-blue-100 hover:bg-blue-200 transition-colors">
                            <i class="bi bi-plus-lg mr-1"></i> Novo Metadado
                        </button>
                    </div>

                    <div class="border rounded-md overflow-hidden">
                        <table class="min-w-full divide-y divide-gray-200" id="tabelaMetadados">
                            <thead class="bg-gray-50">
                                <tr>
                                    <th scope="col" class="px-6 py-3 text-left text-xs font-bold text-gray-500 uppercase w-16">#</th>
                                    <th scope="col" class="px-6 py-3 text-center text-xs font-bold text-gray-500 uppercase w-24">Selecionar</th>
                                    <th scope="col" class="px-6 py-3 text-left text-xs font-bold text-gray-500 uppercase">Metadado</th>
                                    <th scope="col" class="px-6 py-3 text-right text-xs font-bold text-gray-500 uppercase w-32"></th>
                                </tr>
                            </thead>
                            <tbody class="bg-white divide-y divide-gray-200" id="tbodyMetadados">
                                @if (Model.metadadosDocumentos != null)
                                {
                                    int i = 1;
                                    @foreach (var tipo in Model.metadadosDocumentos)
                                    {
                                        <tr class="hover:bg-gray-50 transition-colors">
                                            <td class="px-6 py-4 text-sm text-gray-500">@i</td>
                                            <td class="px-6 py-4 text-center">
                                                <input type="checkbox" name="MetadadosSelecionados" value="@tipo.Id"
                                                       @(tipo.Selecionado != 0 ? "checked" : "")
                                                       class="h-4 w-4 text-blue-600 border-gray-300 rounded focus:ring-blue-500" />
                                            </td>
                                            <td class="px-6 py-4 text-sm text-gray-900 font-medium">@tipo.Nome</td>
                                            <td class="px-6 py-4 text-right whitespace-nowrap text-sm font-medium">
                                                <button type="button" class="text-amber-600 hover:text-amber-900 mx-1" title="Editar">
                                                    <i class="bi bi-pencil"></i>
                                                </button>
                                                <button type="button" class="text-red-600 hover:text-red-900 mx-1" title="Excluir">
                                                    <i class="bi bi-trash"></i>
                                                </button>
                                            </td>
                                        </tr>
                                        i++;
                                    }
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>

            <div class="bg-gray-50 px-6 py-4 flex items-center justify-end gap-3 border-t border-gray-200">
                <a asp-controller="TipoDocumento" asp-action="Index"
                   class="px-4 py-2 border border-gray-300 rounded-md shadow-sm text-sm font-medium text-gray-700 bg-white hover:bg-gray-50 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-blue-500">
                    Cancelar
                </a>
                <button type="submit" id="btnSalvar"
                        class="px-4 py-2 border border-transparent rounded-md shadow-sm text-sm font-medium text-white bg-green-600 hover:bg-green-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-green-500">
                    <i class="bi bi-check-lg mr-1"></i> Salvar
                </button>
            </div>
        </div>
    </form>
</div>

<div id="metadadoModal" class="fixed inset-0 z-50 hidden" aria-labelledby="modal-title" role="dialog" aria-modal="true">
    <div class="fixed inset-0 bg-gray-500 bg-opacity-75 transition-opacity backdrop-blur-sm" onclick="toggleModal(false)"></div>

    <div class="fixed inset-0 z-10 overflow-y-auto">
        <div class="flex min-h-full items-center justify-center p-4 text-center">
            <div class="relative transform overflow-hidden rounded-lg bg-white text-left shadow-xl transition-all sm:w-full sm:max-w-md">

                <div class="bg-white px-4 pb-4 pt-5 sm:p-6 sm:pb-4">
                    <h3 class="text-lg font-semibold leading-6 text-gray-900 mb-4" id="modal-title">Novo Metadado</h3>
                    <div>
                        <input type="text" id="inputNovoMetadado"
                               class="w-full rounded-md border border-gray-300 px-3 py-2 text-gray-900 focus:border-blue-500 focus:ring-blue-500 sm:text-sm"
                               placeholder="Digite o nome do metadado..." />
                    </div>
                </div>

                <div class="bg-gray-50 px-4 py-3 sm:flex sm:flex-row-reverse sm:px-6">
                    <button type="button" onclick="salvarMetadado()"
                            class="inline-flex w-full justify-center rounded-md bg-blue-600 px-3 py-2 text-sm font-semibold text-white shadow-sm hover:bg-blue-500 sm:ml-3 sm:w-auto">
                        Salvar
                    </button>
                    <button type="button" onclick="toggleModal(false)"
                            class="mt-3 inline-flex w-full justify-center rounded-md bg-white px-3 py-2 text-sm font-semibold text-gray-900 shadow-sm ring-1 ring-inset ring-gray-300 hover:bg-gray-50 sm:mt-0 sm:w-auto">
                        Cancelar
                    </button>
                </div>
            </div>
        </div>
    </div>
</div>

<script>
    // 1. Função para abrir/fechar modal
    function toggleModal(show) {
        const modal = document.getElementById('metadadoModal');
        const input = document.getElementById('inputNovoMetadado');

        if (show) {
            modal.classList.remove('hidden');
            input.value = ''; // Limpa input ao abrir
            setTimeout(() => input.focus(), 100); // Foca no input
        } else {
            modal.classList.add('hidden');
        }
    }

    // 2. Salvar Metadado via AJAX
    function salvarMetadado() {
        var nome = document.getElementById('inputNovoMetadado').value;

        if (!nome.trim()) {
            alert("Digite um nome para o metadado.");
            return;
        }

        // Pega o token CSRF gerado pelo ASP.NET dentro do form principal
        const token = document.querySelector('input[name="__RequestVerificationToken"]')?.value;

        fetch('/TipoDocumento/NovoMetadado', {
            method: 'POST',
            headers: {
                'Content-Type': 'application/json',
                'RequestVerificationToken': token
            },
            body: JSON.stringify(nome)
        })
        .then(response => response.json())
        .then(data => {
            if (data.sucesso) {
                var tbody = document.getElementById('tbodyMetadados');
                var novaLinha = document.createElement('tr');

                // Aplica as classes Tailwind na nova linha para manter consistência
                novaLinha.className = "hover:bg-gray-50 transition-colors bg-green-50 animate-pulse"; // bg-green-50 destaca que foi recém criado

                novaLinha.innerHTML = `
                    <td class="px-6 py-4 text-sm text-gray-500">#</td>
                    <td class="px-6 py-4 text-center">
                        <input type="checkbox" name="MetadadosSelecionados" value="${data.metadado.id}"
                               class="h-4 w-4 text-blue-600 border-gray-300 rounded focus:ring-blue-500" />
                    </td>
                    <td class="px-6 py-4 text-sm text-gray-900 font-medium">${data.metadado.name}</td>
                    <td class="px-6 py-4 text-right whitespace-nowrap text-sm font-medium">
                        <button type="button" class="text-amber-600 hover:text-amber-900 mx-1"><i class="bi bi-pencil"></i></button>
                        <button type="button" class="text-red-600 hover:text-red-900 mx-1"><i class="bi bi-trash"></i></button>
                    </td>
                `;

                tbody.appendChild(novaLinha);

                // Remove o destaque visual (bg-green-50) após 2 segundos
                setTimeout(() => {
                    novaLinha.classList.remove('bg-green-50', 'animate-pulse');
                }, 2000);

                toggleModal(false);
            } else {
                alert("Erro ao salvar metadado.");
            }
        })
        .catch(error => {
            console.error('Erro:', error);
            alert("Ocorreu um erro na requisição.");
        });
    };

    // 3. Validação do formulário principal
    document.getElementById("mainForm").addEventListener("submit", function (e) {
        var nomeInput = document.querySelector('input[name="Name"]');
        var spanErro = document.getElementById("validaNome");
        var nome = nomeInput.value;

        if (!nome.trim()) {
            e.preventDefault();
            spanErro.classList.remove('hidden'); // Mostra erro
            nomeInput.classList.add('border-red-500', 'focus:ring-red-500'); // Destaca input
            nomeInput.focus();
        } else {
            spanErro.classList.add('hidden');
            nomeInput.classList.remove('border-red-500', 'focus:ring-red-500');
        }
    });
</script>