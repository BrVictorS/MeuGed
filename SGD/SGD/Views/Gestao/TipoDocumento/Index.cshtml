@using SGD.Dtos.Response
@model ServiceResponse<List<TipoDocumentalModel>>

<div class="container-sm" style="width:900px">
        <a asp-action="Cadastrar">
            <button type="button" style="width:100px" class="btn btn-primary">Novo</button>
        </a>
        <table class="table table-striped table-hover">
            <thead>
                <tr>
                    <th scope="col">#</th>
                    <th scope="col">Tipo Documento</th>
                    <th scope="col"></th>                    
                    <th scope="col"></th>
                </tr>
            </thead>
            <tbody>
                @if(Model != null){
                    @foreach (var tipo in Model.Dados)
                    {
                        <tr>
                            <th scope="row">1</th>
                            <td>@tipo.Name</td>
                            <td>
                                        @* <a asp-action="Editar" asp-route-id="@tipo.Id"> *@
                                <a asp-action="Editar" asp-route-id="@tipo.Id">
                                        <button type="button" class="btn btn-warning">Editar</button>
                                        </a>
                            </td>
                            <td>
                                <a>
                                    <button type="button" class="btn btn-danger">Excluir</button>
                                </a>
                            </td>
                        </tr>

                    }
                }              
        </table>        

</div>