@addTagHelper *, Microsoft.AspNetCore.Mvc.TagHelpers





<div class="container text-center">
    <div class="row">
        <div class="col">
            <div class="card" style="width: 18rem;">
                <div class="card-body shadow-lg">
                    <img src="@Url.Content("~/Recursos/tralalelo.png")" class="card-img-top" alt="Imagem">

                    <h5 class="card-title">Receber Lote</h5>
                    <a class="btn btn-primary" asp-area="" asp-controller="Gestao" asp-action="ReceberLote">Acessar</a>
                </div>
            </div>
        </div>
        <div class="col">
            <div class="card shadow-lg" style="width: 18rem;">
                <div class="card-body">
                    <img src="@Url.Content("~/Recursos/sahur.jpg")" class="card-img-top" alt="Imagem">

                    <h5 class="card-title">Receber Lote</h5>
                    <a class="btn btn-primary" asp-area="" asp-controller="TipoDocumento" asp-action="Index">Gestão Documental</a>
                </div>
            </div>
        </div>
        <div class="col">
            <div class="card shadow-lg" style="width: 18rem;">
                <div class="card-body">
                    <img src="@Url.Content("~/Recursos/caputinha.jpg")" class="card-img-top" alt="Imagem">
                    <h5 class="card-title">Receber Lote</h5>
                    <a class="btn btn-primary" asp-area="" asp-controller="Gestao" asp-action="ReceberLote">Acessar</a>
                </div>
            </div>
        </div>
    </div>
</div>
