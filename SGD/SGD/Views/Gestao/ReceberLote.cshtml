@model ICollection<LoteModel>

<div id="modalAjax" class="fixed inset-0 z-50 hidden" aria-labelledby="modalAjaxLabel" aria-modal="true" role="dialog">
    <div class="fixed inset-0 bg-black/50 backdrop-blur-sm transition-opacity" onclick="fecharModal()"></div>

    <div class="fixed inset-0 z-10 overflow-y-auto">
        <div class="flex min-h-full items-center justify-center p-4 text-center">
            <div class="relative transform overflow-hidden rounded-2xl bg-white text-left shadow-2xl transition-all w-full max-w-4xl">

                <button onclick="fecharModal()" class="absolute top-4 right-4 text-gray-400 hover:text-gray-600 z-20">
                    <i class="fas fa-times text-xl"></i>
                </button>

                <div id="modalAjaxContent" class="p-8">
                    <div class="flex flex-col items-center justify-center py-12">
                        <div class="w-10 h-10 border-4 border-gray-200 border-t-blue-600 rounded-full animate-spin mb-4"></div>
                        <p class="text-gray-600 font-medium">Carregando...</p>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<div id="principal" class="bg-gradient-to-br from-slate-50 to-blue-50 min-h-screen p-8">
    <div class="w-full mx-auto animate-[fadeIn_0.3s_ease-out]">

        <div class="bg-white rounded-2xl shadow-lg p-8 mb-6 border border-gray-100">
            <div class="flex flex-col md:flex-row items-center justify-between gap-4">
                <div class="flex items-center gap-4">
                    <div class="bg-gradient-to-br from-green-500 to-blue-600 p-4 rounded-xl shadow-lg transform transition hover:scale-105">
                        <i class="fas fa-boxes text-white text-3xl"></i>
                    </div>
                    <div>
                        <h1 class="text-3xl md:text-4xl font-bold text-gray-800">Receber Lote</h1>
                        <p class="text-gray-500 mt-1">Gerencie e organize seus lotes</p>
                    </div>
                </div>

                <button onclick="carregarModal()"
                        class="px-6 py-3 rounded-xl text-white font-semibold shadow-lg flex items-center gap-2 bg-gradient-to-br from-blue-500 to-blue-600 hover:from-blue-600 hover:to-blue-700 transform hover:-translate-y-1 transition-all duration-200">
                    <i class="fas fa-plus"></i> Novo Lote
                </button>
            </div>
        </div>

        <div class="bg-white rounded-2xl shadow-lg overflow-hidden border border-gray-100">
            <div class="overflow-x-auto">
                <table class="w-full">
                    <thead>
                        <tr class="bg-gradient-to-r from-green-600 to-blue-700 text-white">
                            <th class="px-6 py-4 text-left text-sm font-semibold">#</th>
                            <th class="px-6 py-4 text-left text-sm font-semibold"><i class="fas fa-box mr-2"></i>Lote</th>
                            <th class="px-6 py-4 text-left text-sm font-semibold"><i class="fas fa-project-diagram mr-2"></i>Projeto</th>
                            <th class="px-6 py-4 text-left text-sm font-semibold"><i class="fas fa-file-alt mr-2"></i>Descrição</th>
                            <th class="px-6 py-4 text-center text-sm font-semibold"><i class="fas fa-cog mr-2"></i>Ações</th>
                        </tr>
                    </thead>
                    <tbody id="loteTableBody" class="divide-y divide-gray-100">
                        @{
                            int i = 1;
                        }
                        @foreach (var lote in Model)
                        {
                            <tr class="group hover:bg-blue-50 transition-colors duration-200">
                                <td class="px-6 py-4 text-gray-700 font-medium">@i</td>
                                <td class="px-6 py-4 text-gray-800 font-semibold group-hover:text-blue-700 transition-colors">@lote.NumLote</td>
                                <td class="px-6 py-4">
                                    <span class="inline-flex items-center px-3 py-1 rounded-full text-sm font-medium bg-blue-100 text-blue-800 border border-blue-200">
                                        @lote.Projeto.Nome
                                    </span>
                                </td>
                                <td class="px-6 py-4 text-gray-600">@lote.Observacao</td>
                                <td class="px-6 py-4 text-center">
                                    <button onclick="carregarModal(@lote.Id)"
                                            class="inline-flex items-center gap-2 px-4 py-2 bg-white border border-blue-200 text-blue-600 hover:bg-blue-500 hover:text-white rounded-lg font-medium transition-all duration-200 shadow-sm hover:shadow-md">
                                        <i class="fas fa-edit"></i> Editar
                                    </button>
                                </td>
                            </tr>
                            i++;
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

<script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
<script src="/_sdk/data_sdk.js" type="text/javascript"></script>
<script src="/_sdk/element_sdk.js" type="text/javascript"></script>

<script>
    // 1. Função Genérica para Abrir/Fechar Modal (Sem Bootstrap)
    function toggleModal(show) {
        const modal = document.getElementById('modalAjax');
        if (show) {
            modal.classList.remove('hidden');
        } else {
            modal.classList.add('hidden');
        }
    }

    function fecharModal() {
        toggleModal(false);
    }

    // 2. Conteúdo Padrão de Loading (para resetar o modal ao abrir novamente)
    const loadingContent = `
        <div class="flex flex-col items-center justify-center py-12">
            <div class="w-10 h-10 border-4 border-gray-200 border-t-blue-600 rounded-full animate-spin mb-4"></div>
            <p class="text-gray-600 font-medium">Carregando...</p>
        </div>
    `;

    // 3. Lógica Unificada (Corrige o erro de sobrescrita de função)
    function carregarModal(id = null) {
        // Reseta o conteúdo para o spinner
        $('#modalAjaxContent').html(loadingContent);

        // Abre o modal visualmente
        toggleModal(true);

        // Define URL e Dados com base na existência do ID
        let url, data;

        if (id) {
            // Modo Edição
            url = '/Lote/Editar';
            data = { id: id };
        } else {
            // Modo Novo
            url = '/Gestao/NovoLote';
            data = {};
        }

        // Requisição AJAX
        $.get(url, data, function (htmlRetornado) {
            $('#modalAjaxContent').html(htmlRetornado);
        }).fail(function () {
            $('#modalAjaxContent').html(`
                <div class="text-center py-8">
                    <i class="fas fa-exclamation-triangle text-red-500 text-4xl mb-4"></i>
                    <p class="text-gray-800 font-semibold">Erro ao carregar dados.</p>
                    <button onclick="fecharModal()" class="mt-4 text-sm text-gray-500 underline">Fechar</button>
                </div>
            `);
        });
    }
</script>