@model IEnumerable<ProjetoModel>

<div class="min-h-screen bg-gray-50 py-12 px-4 sm:px-6 lg:px-8 font-sans">
    <div class="max-w-4xl mx-auto">
        <div class="bg-white rounded-xl shadow-lg overflow-hidden border border-gray-100">
            
            <div class="px-6 py-5 border-b border-gray-100 bg-white flex justify-between items-center">
                <h2 class="text-lg font-bold text-gray-900">Gerenciar Projetos</h2>
                <button type="button" id="btnOpenCreate"
                        class="bg-blue-600 hover:bg-blue-700 text-white font-medium py-2 px-4 rounded-md shadow-sm transition-colors duration-200 flex items-center">
                    <i class="bi bi-plus-lg mr-2"></i> Novo Objeto
                </button>

               
            </div>
            
           <div class="overflow-x-auto">
                <table class="min-w-full divide-y divide-gray-200">
                    <thead class="bg-gray-50">
                        <tr>
                            <th scope="col" class="px-6 py-3 text-left text-xs font-bold text-gray-500 uppercase tracking-wider">Id</th>
                            <th scope="col" class="px-6 py-3 text-left text-xs font-bold text-gray-500 uppercase tracking-wider">Projeto</th>
                            <th scope="col" class="px-6 py-3 text-right text-xs font-bold text-gray-500 uppercase tracking-wider">Ações</th>
                        </tr>
                    </thead>
                    <tbody class="bg-white divide-y divide-gray-200">
                        @foreach (var projeto in Model)
                        {
                            <tr class="hover:bg-gray-50 transition-colors">
                                <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500">@projeto.Id</td>
                                <td class="px-6 py-4 whitespace-nowrap text-sm font-medium text-gray-900">@projeto.Nome</td>
                                <td class="px-6 py-4 whitespace-nowrap text-right text-sm font-medium">
                                    <div class="inline-flex items-center px-4 py-2 border border-transparent text-sm font-medium rounded-md text-white bg-blue-600 hover:bg-blue-700 shadow-sm transition-all transform active:scale-95 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-blue-500">
                                        <i class="fa-solid fa-pencil"></i>
                                        <hr />
                                        <button type="button"
                                                class="btn-edit"
                                                data-id="@projeto.Id"
                                                data-nome="@projeto.Nome">
                                            Editar
                                        </button>
                                    </div>




                                </td>
                            </tr>
                        }
                    </tbody>
                </table>

            </div>
        </div>
    </div>
</div>

<div id="createModal" class="fixed inset-0 z-50 hidden" aria-labelledby="modal-title" role="dialog" aria-modal="true">
    <div class="fixed inset-0 bg-gray-500 bg-opacity-75 transition-opacity modal-backdrop"></div>

    <div class="fixed inset-0 z-10 overflow-y-auto">
        <div class="flex min-h-full items-end justify-center p-4 text-center sm:items-center sm:p-0">
            <div class="relative transform overflow-hidden rounded-lg bg-white text-left shadow-xl transition-all sm:my-8 sm:w-full sm:max-w-lg">
                <div class="bg-white px-4 pb-4 pt-5 sm:p-6 sm:pb-4">
                    <div class="sm:flex sm:items-start">
                        <div class="mt-3 text-center sm:ml-4 sm:mt-0 sm:text-left w-full">
                            <h3 class="text-lg font-semibold leading-6 text-gray-900" id="modal-title">Criar Novo Objeto</h3>
                            <div class="mt-4">
                                <form id="createForm">
                                    <label for="nomeProjeto" class="block text-sm font-medium leading-6 text-gray-900">Nome</label>
                                    <div class="mt-2">
                                        <input type="text" name="Nome" id="nomeProjeto" required
                                               class="block w-full rounded-md border-0 py-1.5 text-gray-900 shadow-sm ring-1 ring-inset ring-gray-300 placeholder:text-gray-400 focus:ring-2 focus:ring-inset focus:ring-blue-600 sm:text-sm sm:leading-6 px-3">
                                    </div>
                                </form>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="bg-gray-50 px-4 py-3 sm:flex sm:flex-row-reverse sm:px-6">
                    <button type="button" id="saveButton" class="inline-flex w-full justify-center rounded-md bg-blue-600 px-3 py-2 text-sm font-semibold text-white shadow-sm hover:bg-blue-500 sm:ml-3 sm:w-auto">Salvar</button>
                    <button type="button" class="mt-3 inline-flex w-full justify-center rounded-md bg-white px-3 py-2 text-sm font-semibold text-gray-900 shadow-sm ring-1 ring-inset ring-gray-300 hover:bg-gray-50 sm:mt-0 sm:w-auto btn-close-modal">Cancelar</button>
                </div>
            </div>
        </div>
    </div>
</div>

<div id="editModal" class="fixed inset-0 z-50 hidden" aria-labelledby="modal-title" role="dialog" aria-modal="true">
    <div class="fixed inset-0 bg-gray-500 bg-opacity-75 transition-opacity modal-backdrop"></div>

    <div class="fixed inset-0 z-10 overflow-y-auto">
        <div class="flex min-h-full items-end justify-center p-4 text-center sm:items-center sm:p-0">
            <div class="relative transform overflow-hidden rounded-lg bg-white text-left shadow-xl transition-all sm:my-8 sm:w-full sm:max-w-lg">
                <div class="bg-white px-4 pb-4 pt-5 sm:p-6 sm:pb-4">
                    <h3 class="text-lg font-semibold leading-6 text-gray-900 mb-4">Editar Projeto</h3>

                    <form id="editForm">
                        <input type="hidden" id="editProjetoId">

                        <div class="mb-4">
                            <label for="editNomeProjeto" class="block text-sm font-medium leading-6 text-gray-900">Nome do Projeto</label>
                            <input type="text" id="editNomeProjeto" name="Nome" required
                                   class="mt-2 block w-full rounded-md border-0 py-1.5 text-gray-900 shadow-sm ring-1 ring-inset ring-gray-300 placeholder:text-gray-400 focus:ring-2 focus:ring-inset focus:ring-blue-600 sm:text-sm sm:leading-6 px-3">
                        </div>

                        <div class="mt-4 border rounded-md overflow-hidden">
                            <div class="max-h-60 overflow-y-auto">
                                <table class="min-w-full divide-y divide-gray-200" id="UsuariosProjetos">
                                    <thead class="bg-gray-50 sticky top-0">
                                        <tr>
                                            <th scope="col" class="px-6 py-3 text-left text-xs font-bold text-gray-500 uppercase">Usuario</th>
                                            <th scope="col" class="px-6 py-3 text-center text-xs font-bold text-gray-500 uppercase">Alocado</th>
                                        </tr>
                                    </thead>
                                    <tbody class="bg-white divide-y divide-gray-200" id="UsuariosProjetosBody">
                                    </tbody>
                                </table>
                            </div>
                        </div>
                    </form>
                </div>
                <div class="bg-gray-50 px-4 py-3 sm:flex sm:flex-row-reverse sm:px-6">
                    <button type="button" id="saveEditButton" class="inline-flex w-full justify-center rounded-md bg-blue-600 px-3 py-2 text-sm font-semibold text-white shadow-sm hover:bg-blue-500 sm:ml-3 sm:w-auto">Salvar Alterações</button>
                    <button type="button" class="mt-3 inline-flex w-full justify-center rounded-md bg-white px-3 py-2 text-sm font-semibold text-gray-900 shadow-sm ring-1 ring-inset ring-gray-300 hover:bg-gray-50 sm:mt-0 sm:w-auto btn-close-modal">Cancelar</button>
                </div>
            </div>
        </div>
    </div>
</div>

<script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>

<script>
    $(document).ready(function () {

        // --- LÓGICA DE ABERTURA/FECHAMENTO DE MODAIS (Tailwind/jQuery) ---

        // Abrir Criar
        $("#btnOpenCreate").click(function() {
            $("#createModal").fadeIn(200).removeClass("hidden");
        });

        // Fechar Modais (Botão Cancelar ou Clicar fora)
        $(".btn-close-modal, .modal-backdrop").click(function() {
            $(this).closest(".fixed.z-50").fadeOut(200, function() {
                $(this).addClass("hidden");
            });
        });

        // --- AJAX: SALVAR NOVO ---
        $("#saveButton").click(function () {
            let projeto = {
                Nome: $("#nomeProjeto").val(),
                Usuarios: [],
                Lote: []
            };

            $.ajax({
                url: "/Projeto/Cadastrar",
                type: "POST",
                contentType: "application/json",
                data: JSON.stringify(projeto),
                success: function (response) {
                    if (response.success) {
                        alert(response.message);
                        $("#createModal").fadeOut();
                        location.reload();
                    } else {
                        console.log(response.errors);
                        alert("Erro ao cadastrar: " + response.message);
                    }
                },
                error: function () {
                    alert("Erro ao salvar o projeto.");
                }
            });
        });

        // --- ABRIR EDITAR ---
        // (Usei delegação de evento 'on' caso a tabela seja recarregada dinamicamente no futuro)
        $(document).on("click", ".btn-edit", function () {
            const id = $(this).data("id");
            const nome = $(this).data("nome");

            // Preencher campos
            $("#editProjetoId").val(id);
            $("#editNomeProjeto").val(nome);

            // Limpa tabela anterior e mostra loading se quiser
            $("#UsuariosProjetosBody").html('<tr><td colspan="2" class="text-center py-4">Carregando...</td></tr>');

            // Abrir Modal
            $("#editModal").fadeIn(200).removeClass("hidden");

            // AJAX buscar usuários
            $.ajax({
                url: `/Projeto/ListarUsuarios/${id}`,
                type: "GET",
                success: function (usuarios) {
                    let linhasTabela = "";

                    usuarios.forEach(usuario => {
                        const isChecked = usuario.alocadoProjeto ? "checked" : "";

                        linhasTabela += `
                            <tr>
                                <td style="display: none;" name="idusuario">${usuario.id}</td>
                                <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-700">${usuario.nome}</td>
                                <td class="px-6 py-4 whitespace-nowrap text-center">
                                    <input type="checkbox" name="atribuido" ${isChecked}
                                           class="h-4 w-4 rounded border-gray-300 text-blue-600 focus:ring-blue-600">
                                </td>
                            </tr>`;
                    });

                    // Importante: Alvo agora é o TBODY, não a TABLE inteira
                    $("#UsuariosProjetosBody").html(linhasTabela);
                },
                error: function () {
                    alert("Erro ao carregar usuários.");
                    $("#UsuariosProjetosBody").html('<tr><td colspan="2" class="text-center text-red-500">Erro ao carregar dados.</td></tr>');
                }
            });
        });

        // --- AJAX: SALVAR EDIÇÃO ---
        $("#saveEditButton").click(function () {
            const formData = {
                Id: $("#editProjetoId").val(),
                Nome: $("#editNomeProjeto").val(),
                UsuariosProjetos : []
            };

            // Iterar sobre o TBODY para pegar os dados
            $("#UsuariosProjetosBody tr").each(function () {
                const usuarioId = $(this).find("td[name='idusuario']").text().trim();
                const alocado = $(this).find("input[name='atribuido']").prop("checked");

                if (alocado) {
                    formData.UsuariosProjetos.push({
                        UsuarioId: usuarioId,
                        ProjetoId: formData.Id
                    });
                }
            });

            $.ajax({
                url: "/Projeto/Editar",
                type: "POST",
                contentType: "application/json",
                data: JSON.stringify(formData),
                success: function (response) {
                    if (response.success) {
                        alert(response.message);
                        $("#editModal").fadeOut();
                        location.reload();
                    } else {
                        alert("Erro ao salvar: " + response.message);
                    }
                },
                error: function () {
                    alert("Erro ao salvar o projeto.");
                }
            });
        });
    });
</script>