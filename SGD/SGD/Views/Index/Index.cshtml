@using SGD.Models.ViewModels
@model IndexacaoViewModel
<style>
    body {
        font-family: 'Lucida Sans', 'Lucida Sans Regular', 'Lucida Grande', 'Lucida Sans Unicode', Geneva, Verdana, sans-serif;
        font-size: small;
        height: 100vh;
    }

    .container-custom {
        display: flex;
        height: 100vh;
    }

    .left-panel {
        display: flex;
        flex-direction: column;
        height: 100%;
        width: 25%;
        
        box-sizing: border-box;
        background: #f8f9fa;
        gap: 0px;
    }

    .right-panel {
        width: 60%;
        display: flex;
        align-items: center;
        justify-content: center;
        background: #fff;
        border-left: 1px solid #ddd;
    }

    .image-display {
        max-width: 90%;
        max-height: 90%;
        border: 1px solid #ccc;
        background: #fafafa;
        object-fit: contain;
    }

    label {
        display: block;
        margin-bottom: 6px;
        font-weight: 500;
    }

    select, input[type="text"] {
        width: 100%;
        font-size: 1rem;
        box-sizing: border-box;
    }

    table {
        width: 100%;
        border-collapse: collapse;
    }

    th, td {
        padding: 8px;
        text-align: left;
        border-bottom: 1px solid #ccc;
        background-color: gold;
    }

    th {
        background: #ffffff;
    }

    .meta-scroll {
        flex: 1 1 auto; /* ocupa o restante */
        min-height: 0; /* permite overflow em container flex */
        overflow-y: auto; /* barra de rolagem vertical */
        padding-right: 4px; /* evita esconder conteúdo sob a barra */
    }

    .table-scroll {
        max-height: 120px; /* altura suficiente para 2 linhas + cabeçalho */
        overflow-y: auto;
        display: block;
        margin-bottom: 20px;
    }

        .table-scroll thead,
        .table-scroll tbody tr {
            display: table;
            width: 100%;
            table-layout: fixed; /* mantém colunas alinhadas */
        }

    .selecionado{
        background-color:dodgerblue;
    }

</style>
<body>
    <div class="container-custom">
        <div class="left-panel bg-light p-4 rounded shadow-sm">
            <div class="table-scroll">
                <table id="documentTable" class="table table-striped table-bordered">
                    <thead class="table-light">
                        <tr>
                            <th>Documento</th>
                        </tr>
                    </thead>
                    <colgroup>
                        <col style="width:90%">
                        <col style="width:1%">
                    </colgroup>
                    <tbody id="tablebody">
                        @{
                            foreach (var d in Model.Documentos)
                            {
                                <tr>
                                    <td>@d</td>
                                </tr>
                            }
                        }
                    </tbody>
                </table>
            </div>

            <div class="">
                <label for="docType" class="form-label">Document Type</label>
                <select id="docType" class="form-select">
                    <option selected disabled>Select a type</option>
                    @{
                        foreach (var dt in Model.TiposDocumento)
                        {
                            <option value="@dt.Id">@dt.Name</option>
                        }
                    }
                </select>
            </div>

            <div class="meta-scroll">
                <form id="metadataPanel">
                </form>
                
            </div>
            <div>
                <button id="salvaDoc" type="button" class="btn btn-primary">Salvar documento</button>
            </div>
        </div>
        <div class="right-panel d-flex align-items-center justify-content-center bg-white border-start">
            <img id="previewImg" class="image-display img-fluid rounded border" alt="Document Preview">
        </div>
    </div>
</body>
<script>
    const idLote = @Html.Raw(Json.Serialize(Model.IdLote));
    const tiposDocumento = @Html.Raw(Json.Serialize(Model.TiposDocumento));
    let selectedIndex;
    const selectElement = document.getElementById('docType');
    const metadataPanel = document.getElementById('metadataPanel');
    const tablebody = document.getElementById('tablebody');
    const btnSalvarDoc = document.getElementById('salvaDoc');
    let tipodocselecionado;


    function carregaMetadados(idDoTipo) {
        metadataPanel.innerHTML = '';

        if (!idDoTipo) {
            return;
        }

        const tipoSelecionado = tiposDocumento.find(tipo => tipo.id == parseInt(idDoTipo));

        if (tipoSelecionado && tipoSelecionado.metadados) {
            tipoSelecionado.metadados.forEach(meta => {
                const formGroup = document.createElement('div');
                formGroup.className = 'mb-3'; 

                const label = document.createElement('label');
                label.className = 'form-label';
                label.textContent = meta.nome;
                label.htmlFor = 'meta_' + meta.nome;

                const input = document.createElement('input');
                input.className = 'form-control';
                input.type = 'text'; 
                input.id = 'meta_' + meta.nome;
                input.name = meta.nome;

                formGroup.appendChild(label);
                formGroup.appendChild(input);
                metadataPanel.appendChild(formGroup);
            });
        }
    }

    selectElement.addEventListener('change', function(event) {
        tipodocselecionado = event.target.value;
        carregaMetadados(tipodocselecionado);
    });

    tablebody.addEventListener('click',function(e){
        const row = e.target.closest('tr');
        tablebody.querySelectorAll('tr').forEach(r => r.classList.remove('selecionado'));
        selectedIndex = Array.from(tablebody.children).indexOf(row);
        row.classList.add('selecionado');
        
        carregaMetadados(tipodocselecionado);

        const previewImg = document.getElementById('previewImg');

        fetch("/Verify/MostrarImagemIndex", {
                method: "POST",
                headers: {
                "Content-Type": "application/json"
                },
                body: JSON.stringify(row.outerText)
                })
                .then(res => res.blob())
                .then(blob => {
                previewImg.src = URL.createObjectURL(blob);
                });

        
    });

    btnSalvarDoc.addEventListener('click', async function(e){
        var metadados = document.getElementById('metadataPanel').querySelectorAll('input');
        var valores = {};
        let doc =  document.querySelector('.selecionado');

        if(doc){
            valores['idDocumento'] = doc.outerText;
            valores['idTipoDoc'] = selectElement.value;
            valores['idLote'] = idLote;
            metadados.forEach(input => {
            valores[input.name] = input.value;
        });

        await fetch('/Index/InsereIndexacaoDocumento',{
            method: "POST",
                headers: {
                "Content-Type": "application/json"
                },
                body:JSON.stringify(valores)
        }).then(r => r.text())
                .then(html => showAlert(html));
        }
        else{
            showMensagem('Selecione um documento para ser indexado!','erro');
        }
        
    });
    
    
    

</script>