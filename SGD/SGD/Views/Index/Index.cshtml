@using SGD.Models.ViewModels
@model IndexacaoViewModel
<style>
    html, body {
        height: 100vh;       
        margin: 0;
        padding: 0;
        overflow-y: hidden; /* Garante scroll só quando necessário */
        overflow:hidden;
    }

    body {
        font-family: 'Lucida Sans', 'Lucida Sans Regular', 'Lucida Grande', 'Lucida Sans Unicode', Geneva, Verdana, sans-serif;
        font-size: small;
        min-height: 100vh;
        height: 100vh;
        box-sizing: border-box;
    }

    .container-custom {
        display: flex;
        min-height: 100vh;
        height: 100vh;
    }

    .left-panel {
        display: flex;
        flex-direction: column;
        height: 100%;
        width: 25%;
        box-sizing: border-box;
        background: #f8f9fa;
        gap: 0px;
    }

    .right-panel {
        width: 60%;
        display: flex;
        align-items: center;
        justify-content: center;
        background: #fff;
        border-left: 1px solid #ddd;
    }

    .image-display {
       height:100vh;
        border: 1px solid #ccc;
        background: #fafafa;
        object-fit: contain;
    }

    label {
        display: block;
        margin-bottom: 6px;
        font-weight: 500;
    }

    select, input[type="text"] {
        width: 100%;
        font-size: 1rem;
        box-sizing: border-box;
    }

    table {
        width: 100%;
        border-collapse: collapse;
    }

    th, td {
        padding: 8px;
        text-align: left;
        border-bottom: 1px solid #ccc;
        background-color: gold;
    }

    th {
        background: #ffffff;
    }

    .meta-scroll {
        flex: 1 1 auto;
        min-height: 0;
        overflow-y: auto;
        padding-right: 4px;
    }

    .table-scroll {
        max-height: 120px;
        overflow-y: auto;
        display: block;
        margin-bottom: 20px;
    }

        .table-scroll thead,
        .table-scroll tbody tr {
            display: table;
            width: 100%;
            table-layout: fixed;
        }

    .selecionado{
        background-color:dodgerblue;
    }

</style>
<body>
    <div class="container-custom">
        <div class="left-panel bg-light p-4 rounded shadow-sm">
            <div class="table-scroll">
                <table id="documentTable" class="table table-striped table-bordered">
                    <thead class="table-light">
                        <tr>
                            <th>Documento</th>
                        </tr>
                    </thead>
                    <colgroup>
                        <col style="width:90%">
                        <col style="width:1%">
                    </colgroup>
                    <tbody id="tablebody">
                        @{
                            foreach (var d in Model.Documentos)
                            {
                                <tr>
                                    <td>@d</td>
                                </tr>
                            }
                        }
                    </tbody>
                </table>
            </div>
            <div class="">
                <label for="docType" class="form-label">Document Type</label>
                <select id="docType" class="form-select">
                    <option selected disabled>Select a type</option>
                    @{
                        foreach (var dt in Model.TiposDocumento)
                        {
                            <option value="@dt.Id">@dt.Name</option>
                        }
                    }
                </select>
            </div>
            <div class="meta-scroll">
                <form id="metadataPanel">
                </form>
                
            </div>
            <div>
                <button id="salvaDoc" type="button" class="btn btn-primary">Salvar documento (F10)</button>
            </div>
            <a asp-action="FinalizaLote">
                <button type="button" id="btnFinaliza" class="btn btn-primary shadow-sm rounded px-4 mt-2 mt-md-0">
                <i class="bi bi-check2-circle"></i> Finalizar Lote
            </button>
            </a>
        </div>
        <div class="right-panel d-flex align-items-center justify-content-center bg-white border-start">
            <img id="previewImg" class="image-display img-fluid rounded border" alt="Document Preview">
        </div>
    </div>
</body>
<script>
    const idLote = @Html.Raw(Json.Serialize(Model.IdLote));
    const tiposDocumento = @Html.Raw(Json.Serialize(Model.TiposDocumento));
</script>
<script src="~/js/indexacao.js" asp-append-version="true"></script>