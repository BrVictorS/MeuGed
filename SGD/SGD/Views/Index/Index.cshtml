@using SGD.Models.ViewModels
@model IndexacaoViewModel

<div class="flex h-screen w-full bg-gray-100 overflow-hidden font-sans">

    <div class="w-96 flex flex-col bg-white border-r border-gray-200 shadow-xl z-20 flex-shrink-0">

        <div class="flex-none h-1/3 flex flex-col border-b border-gray-200">
            <div class="px-4 py-3 bg-gray-50 border-b border-gray-200 flex justify-between items-center">
                <h5 class="text-xs font-bold text-gray-500 uppercase tracking-wider">Documentos</h5>
                <span class="bg-blue-100 text-blue-800 text-xs font-semibold px-2 py-0.5 rounded-full">
                    @Model.Documentos.Count
                </span>
            </div>

            <div class="flex-1 overflow-y-auto custom-scrollbar bg-white">
                <table id="documentTable" class="min-w-full divide-y divide-gray-100">
                    <tbody id="tablebody">
                        @foreach (var d in Model.Documentos)
                        {
                            <tr class="hover:bg-blue-50 cursor-pointer transition-colors group border-b border-gray-50 last:border-0">
                                <td class="px-4 py-3 text-sm text-gray-700 group-hover:text-blue-700 flex items-center gap-2">
                                    <i class="bi bi-file-earmark-text text-gray-400 group-hover:text-blue-500"></i>
                                    <span class="truncate">@d</span>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>

        <div class="p-5 border-b border-gray-200 bg-gray-50/50">
            <label for="docType" class="block text-xs font-bold text-gray-700 uppercase tracking-wider mb-2">
                Tipo Documental
            </label>
            <div class="relative">
                <select id="docType" class="block w-full rounded-lg border-gray-300 shadow-sm focus:border-blue-500 focus:ring-blue-500 sm:text-sm py-2.5 px-3">
                    <option selected disabled>Selecione um tipo...</option>
                    @foreach (var dt in Model.TiposDocumento)
                    {
                        <option value="@dt.Id">@dt.Name</option>
                    }
                </select>
                <div class="pointer-events-none absolute inset-y-0 right-0 flex items-center px-2 text-gray-700">
                    <i class="bi bi-chevron-down text-xs"></i>
                </div>
            </div>
        </div>

        <div class="flex-1 flex flex-col min-h-0 bg-white">
            <div class="px-5 py-3 border-b border-gray-100">
                <h5 class="text-xs font-bold text-gray-500 uppercase tracking-wider">Metadados</h5>
            </div>
            <div class="flex-1 overflow-y-auto p-5 custom-scrollbar">
                <form id="metadataPanel" class="space-y-4">
                    <div class="text-center py-8">
                        <i class="bi bi-arrow-up-circle text-3xl text-gray-300 mb-2 block"></i>
                        <p class="text-xs text-gray-400 italic">Selecione um tipo documental acima.</p>
                    </div>
                </form>
            </div>
        </div>

        <div class="p-4 border-t border-gray-200 bg-gray-50 space-y-3">
            <button id="salvaDoc" type="button"
                    class="w-full flex items-center justify-center gap-2 px-4 py-2.5 bg-blue-600 hover:bg-blue-700 text-white text-sm font-bold rounded-lg shadow-sm hover:shadow-md transition-all focus:ring-2 focus:ring-offset-2 focus:ring-blue-500">
                <i class="bi bi-save"></i> Salvar (F10)
            </button>

            <a asp-action="FinalizaLote" class="block w-full">
                <button type="button" id="btnFinaliza"
                        class="w-full flex items-center justify-center gap-2 px-4 py-2.5 bg-green-600 hover:bg-green-700 text-white text-sm font-bold rounded-lg shadow-sm hover:shadow-md transition-all focus:ring-2 focus:ring-offset-2 focus:ring-green-500">
                    <i class="bi bi-check2-circle"></i> Finalizar Lote
                </button>
            </a>
        </div>
    </div>

    <div class="flex-1 flex flex-col bg-slate-800 relative overflow-hidden">
        <div class="absolute top-4 right-4 z-10 opacity-50 hover:opacity-100 transition-opacity">
            <div class="bg-black/40 backdrop-blur-md text-white px-3 py-1 rounded-full text-xs flex items-center gap-2 border border-white/10">
                <i class="bi bi-eye"></i> Visualizador
            </div>
        </div>

        <div class="flex-1 flex items-center justify-center p-4 relative w-full h-full">
            <img id="previewImg" src="" alt=""
                 class="max-w-full max-h-full object-contain shadow-2xl transition-opacity duration-300 opacity-0"
                 onload="this.classList.remove('opacity-0')"
                 >
        </div>
    </div>
</div>

<style>
    /* Scrollbar Fina */
    .custom-scrollbar::-webkit-scrollbar {
        width: 6px;
    }

    .custom-scrollbar::-webkit-scrollbar-track {
        background: transparent;
    }

    .custom-scrollbar::-webkit-scrollbar-thumb {
        background: #cbd5e1;
        border-radius: 3px;
    }

        .custom-scrollbar::-webkit-scrollbar-thumb:hover {
            background: #94a3b8;
        }

    /* Compatibilidade: Linha Selecionada (Adicionada pelo indexacao.js) */
    .selecionado {
        background-color: #eff6ff !important; /* bg-blue-50 */
        border-left: 4px solid #2563eb !important; /* border-blue-600 */
    }

        .selecionado td {
            color: #1d4ed8 !important; /* text-blue-700 */
            font-weight: 600;
        }

    /* Compatibilidade: Inputs gerados dinamicamente pelo JS (Bootstrap classes) */
    .form-control, .form-select {
        display: block;
        width: 100%;
        padding: 0.5rem 0.75rem;
        font-size: 0.875rem;
        line-height: 1.25rem;
        color: #1f2937;
        background-color: #fff;
        border: 1px solid #d1d5db;
        border-radius: 0.5rem;
        box-shadow: 0 1px 2px 0 rgba(0, 0, 0, 0.05);
        transition: border-color 0.15s ease-in-out, box-shadow 0.15s ease-in-out;
    }

        .form-control:focus, .form-select:focus {
            outline: none;
            border-color: #3b82f6;
            box-shadow: 0 0 0 3px rgba(59, 130, 246, 0.2);
        }

    label {
        display: block;
        margin-bottom: 0.25rem;
        font-size: 0.75rem;
        font-weight: 600;
        text-transform: uppercase;
        color: #4b5563;
        letter-spacing: 0.025em;
    }
</style>

<script>
    const idLote = @Html.Raw(Json.Serialize(Model.IdLote));
    const tiposDocumento = @Html.Raw(Json.Serialize(Model.TiposDocumento));
</script>
<script src="~/js/indexacao.js" asp-append-version="true"></script>