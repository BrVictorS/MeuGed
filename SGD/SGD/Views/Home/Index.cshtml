@using SGD.Dtos.Login
@using Microsoft.AspNetCore.Http
@model LoginDto
@*
    For more information on enabling MVC for empty projects, visit https://go.microsoft.com/fwlink/?LinkID=397860
*@

@if (ViewBag.DeslogadoMsg != null)
{
    <div class="alert alert-danger text-dark" role="alert">
        @ViewBag.DeslogadoMsg
    </div>
}

<style>
    .animate-fade-in {
        animation: fadeIn 0.6s ease-out;
    }

    .input-field {
        transition: all 0.3s ease;
    }

        .input-field:focus {
            transform: translateY(-2px);
            box-shadow: 0 10px 25px rgba(59, 130, 246, 0.15);
        }

    .btn-primary {
        background: linear-gradient(135deg, #3b82f6 0%, #2563eb 100%);
        transition: all 0.3s ease;
    }

        .btn-primary:hover {
            background: linear-gradient(135deg, #2563eb 0%, #1d4ed8 100%);
            transform: translateY(-2px);
            box-shadow: 0 10px 20px rgba(59, 130, 246, 0.4);
        }
</style>
<div class="bg-gradient-to-br from-blue-500 via-blue-600 to-indigo-700 min-h-full flex items-center justify-center p-4">
    <div class="h-screen">
        <div class="animate-fade-in">
            <!-- Card -->
            <div class="bg-white rounded-2xl shadow-2xl overflow-hidden">
                <!-- Header -->
                <div class="bg-gradient-to-r from-blue-500 to-indigo-600 px-8 py-6 text-center">
                    <h3 class="text-2xl font-bold text-white">MIGED</h3>

                </div><!-- Body -->
                <div class="px-8 py-8">
                    <form asp-action="login" asp-controller="Home" method="post">
                        <!-- Email -->
                        <div class="mb-6">
                            <label for="inputEmail" class="block text-sm font-semibold text-gray-700 mb-2"> Email </label>
                            <div class="relative">
                                <div class="absolute inset-y-0 left-0 pl-4 flex items-center pointer-events-none">
                                    <i class="fas fa-envelope text-gray-400"></i>
                                </div><input class="input-field w-full pl-11 pr-4 py-3 border-2 border-gray-200 rounded-xl focus:border-blue-500 focus:ring-0 focus:outline-none text-gray-800" id="inputEmail" type="email" asp-for="Email" placeholder="usuario@exemplo.com">
                            </div><span asp-validation-for="Email" class="text-red-500 text-sm mt-1 block"></span>
                        </div><!-- Password -->
                        <div class="mb-6">
                            <label for="inputPassword" class="block text-sm font-semibold text-gray-700 mb-2"> Senha </label>
                            <div class="relative">
                                <div class="absolute inset-y-0 left-0 pl-4 flex items-center pointer-events-none">
                                    <i class="fas fa-lock text-gray-400"></i>
                                </div><input class="input-field w-full pl-11 pr-4 py-3 border-2 border-gray-200 rounded-xl focus:border-blue-500 focus:ring-0 focus:outline-none text-gray-800" id="inputPassword" type="password" asp-for="Senha" placeholder="Digite sua senha">
                            </div><span asp-validation-for="Senha" class="text-red-500 text-sm mt-1 block"></span>
                        </div><!-- Remember Password -->
                        <div class="mb-6">
                            <label class="flex items-center gap-2 cursor-pointer group"> <input class="w-4 h-4 text-blue-600 border-2 border-gray-300 rounded focus:ring-2 focus:ring-blue-500 cursor-pointer" id="inputRememberPassword" type="checkbox" value=""> <span class="text-sm text-gray-600 group-hover:text-blue-600 transition-colors"> Lembrar minha senha </span> </label>
                        </div><!-- Submit Button --> <button type="submit" class="btn-primary w-full py-3 text-white font-semibold rounded-xl shadow-lg"> <i class="fas fa-sign-in-alt mr-2"></i> Entrar </button>
                    </form>
                </div><!-- Footer -->
                <div class="bg-gray-50 px-8 py-4 text-center border-t border-gray-100">
                    <p class="text-sm text-gray-600">Não tem conta? <a asp-controller="Usuario" asp-action="Cadastrar" class="text-blue-600 hover:text-blue-700 font-semibold hover:underline transition-colors"> Cadastre-se </a></p>
                </div>
            </div><!-- Extra Info -->
            <div class="text-center mt-6">
                <p class="text-white text-sm opacity-90"><i class="fas fa-shield-alt mr-1"></i> Seus dados estão seguros e protegidos</p>
            </div>
        </div>
    </div>
</div>



