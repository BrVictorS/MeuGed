@using System.Security.Claims
@using SGD.Dtos.Lote
<form id="formulario" method="post" action="/Scan/Salvar" enctype="multipart/form-data">
    <div class="row justify-content-center corpo">
        <div class="d-flex align-items-center">
            <label class="form-label me-2" style="width: 100px;">Usuário</label>
            <input class="form-control txtuser" value="@User.FindFirst(ClaimTypes.Name)?.Value" name="usuario" aria-label="With textarea" readonly="true">
            <input id="idUsuario" name="idUsuario" value="@User.FindFirst(ClaimTypes.NameIdentifier)?.Value" type="hidden" />
        </div>

        <div class="d-flex align-items-center" style="padding-top:20px">
            <label class="form-label me-2" style="width: 100px;">Lote</label>
            <input type="text" class="form-control inptScan" id="NumLote" name="" placeholder="000000" aria-label="Lote" readonly="true">
            <input name="idLote" id="loteid"  type="hidden"/>
        </div>

        <div class="input-group mb-3 uparquivo" style="padding-top: 20px;width:500px">
            <input type="file" class="form-control" id="inputGroupFile01" name="arquivos" webkitdirectory directory multiple>
            <input id="pastaselecionada" name="pasta" type="hidden" />
        </div>
        <button type="submit" class="btn btn-primary">Salvar</button>
    </div>
</form>

<style>
    .corpo {
        display: flex;
        flex-direction: column;
        align-items: flex-start;
        justify-content: flex-start;
        background-color: #f9f9f9;
        border: 1px solid #ccc;
        border-radius: 8px;
        padding: 20px;
        width: 700px;
        margin-bottom: 20px;
    }

    .inptScan {
        width: 300px;
        height: 100px;
    }

    .uparquivo {
        width: 300px;
    }

    .txtuser {
        width: 300px;
    }
</style>

<script>
    const input = document.getElementById('inputGroupFile01');
    const nomePasta = document.getElementById('pastaselecionada');
    const NumLote = document.getElementById('NumLote');    
    const idLote = document.getElementById('loteid');

    input.addEventListener('change', () => {

        

        if (input.files.length > 0) {
            const path = input.files[0].webkitRelativePath;
            const nome = path.split('/')[0]; // pega o nome da pasta raiz            
            NumLote.value = nome;
            enviarLote(nome);
        }                      
    });


    async function enviarLote(NumLote) {
        try {
            const response = await fetch("/Scan/GetLote", {
                method: "POST",
                headers: {
                    "Content-Type": "application/json"
                },
                body: JSON.stringify(NumLote) // ← melhor mandar como objeto
            });

            if (!response.ok) {
                throw new Error("Erro na requisição: " + response.status);
            }

            const data = await response.json(); // ou .text(), depende do que o C# retorna
            idLote.value = data.numlote;
            

        } catch (error) {
            console.error("Erro:", error);
        }
    }


    
    const form = document.getElementById('formulario')


    form.addEventListener('submit',() =>{
        
        const pasta = document.getElementById('inputGroupFile01');
        if (pasta.files.length === 0) {
            event.preventDefault();
            alert('selecione a pasta')
        }

    });

</script>
