@using System.Security.Claims
@using SGD.Dtos.Lote

<div class="min-h-screen flex items-center justify-center bg-gray-50 py-12 px-4 sm:px-6 lg:px-8">
    <div class="max-w-3xl w-full space-y-8">

        <div class="bg-white rounded-2xl shadow-xl overflow-hidden border border-gray-100">

            <div class="px-6 py-5 border-b border-gray-100 bg-white flex justify-between items-center">
                <div class="flex items-center justify-between">
                    <div>
                        <h1 class="text-lg font-bold text-gray-900">
                            <i class="fas fa-barcode"></i> Scan Lote
                        </h1>
                    </div>
                    <div class="h-10 w-10 bg-white/20 rounded-full flex items-center justify-center text-white">
                        <i class="fas fa-folder-open"></i>
                    </div>
                </div>
            </div>

            <form id="formulario" method="post" action="/Scan/Salvar" enctype="multipart/form-data" class="p-8 space-y-8">

                <div class="grid grid-cols-1 md:grid-cols-2 gap-6">

                    <div class="space-y-2">
                        <label for="usuarioDisplay" class="text-sm font-semibold text-gray-700">Usuário Responsável</label>
                        <div class="relative">
                            <div class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none text-gray-400">
                                <i class="fas fa-user"></i>
                            </div>
                            <input type="text"
                                   id="usuarioDisplay"
                                   class="block w-full pl-10 px-4 py-3 bg-gray-50 border border-gray-200 rounded-lg text-gray-600 focus:ring-0 focus:border-gray-200 cursor-not-allowed font-medium"
                                   value="@User.FindFirst(ClaimTypes.Name)?.Value"
                                   readonly>
                            <input id="idUsuario" name="idUsuario" value="@User.FindFirst(ClaimTypes.NameIdentifier)?.Value" type="hidden">
                        </div>
                    </div>

                    <div class="space-y-2">
                        <label for="NumLote" class="text-sm font-semibold text-gray-700">Lote Identificado</label>
                        <div class="relative group">
                            <div class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none text-blue-500">
                                <i class="fas fa-tag"></i>
                            </div>
                            <div id="loadingLote" class="absolute inset-y-0 right-0 pr-3 flex items-center hidden">
                                <svg class="animate-spin h-5 w-5 text-blue-600" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24">
                                    <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
                                    <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path>
                                </svg>
                            </div>

                            <input type="text"
                                   id="NumLote"
                                   class="block w-full pl-10 px-4 py-3 bg-blue-50/50 border border-blue-100 rounded-lg text-blue-800 font-bold font-mono text-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500 transition-all placeholder-blue-200"
                                   placeholder="Aguardando pasta..."
                                   readonly>
                            <input name="idLote" id="loteid" type="hidden">
                        </div>
                        <p class="text-xs text-gray-500" id="statusLote">Selecione a pasta para gerar o número.</p>
                    </div>
                </div>

                <div class="space-y-2">
                    <label class="block text-sm font-semibold text-gray-700">Arquivos do Lote</label>
                    <div class="relative border-2 border-dashed border-gray-300 rounded-xl bg-gray-50 hover:bg-blue-50 hover:border-blue-400 transition-all duration-200 group">

                        <input type="file"
                               id="inputGroupFile01"
                               name="arquivos"
                               webkitdirectory
                               directory
                               multiple
                               class="absolute inset-0 w-full h-full opacity-0 cursor-pointer z-10">

                        <div class="text-center py-10 px-6">
                            <div class="mx-auto h-16 w-16 text-gray-400 group-hover:text-blue-500 transition-colors duration-200 mb-4">
                                <i class="fas fa-cloud-upload-alt text-5xl"></i>
                            </div>
                            <p class="text-sm text-gray-600 font-medium">
                                <span class="text-blue-600 hover:text-blue-700">Clique para selecionar</span> a pasta raiz
                            </p>
                            <p class="text-xs text-gray-500 mt-2">O nome da pasta será usado como número do lote</p>

                            <div id="fileFeedback" class="hidden mt-4 inline-flex items-center px-3 py-1 rounded-full bg-green-100 text-green-800 text-xs font-semibold">
                                <i class="fas fa-check mr-2"></i> <span id="folderNameDisplay">Pasta selecionada</span>
                            </div>
                        </div>
                    </div>
                    <input id="pastaselecionada" name="pasta" type="hidden">
                </div>

                <div class="pt-4 border-t border-gray-100">
                    <button type="submit" id="submit-button" class="w-full flex justify-center items-center gap-2 px-8 py-4 bg-blue-600 hover:bg-blue-700 text-white font-bold rounded-lg shadow-lg hover:shadow-xl transform hover:-translate-y-0.5 transition-all duration-200 focus:outline-none focus:ring-4 focus:ring-blue-500/30 disabled:opacity-50 disabled:cursor-not-allowed">
                        <i class="fas fa-save"></i> Processar e Salvar Lote
                    </button>
                </div>

            </form>
        </div>
    </div>
</div>

<div id="toast" class="fixed bottom-5 right-5 transform translate-y-20 opacity-0 transition-all duration-300 z-50">
    <div class="bg-gray-800 text-white px-6 py-4 rounded-lg shadow-2xl flex items-center gap-3">
        <i id="toastIcon" class="fas fa-info-circle text-blue-400"></i>
        <span id="toastMessage">Mensagem aqui</span>
    </div>
</div>

<script>
    document.addEventListener('DOMContentLoaded', () => {
        const input = document.getElementById('inputGroupFile01');
        const numLoteInput = document.getElementById('NumLote');
        const idLoteInput = document.getElementById('loteid');
        const pastaInput = document.getElementById('pastaselecionada');
        const form = document.getElementById('formulario');

        // Elementos visuais
        const loadingSpinner = document.getElementById('loadingLote');
        const statusText = document.getElementById('statusLote');
        const fileFeedback = document.getElementById('fileFeedback');
        const folderNameDisplay = document.getElementById('folderNameDisplay');

        // --- Evento de Seleção de Pasta ---
        input.addEventListener('change', async () => {
            if (input.files.length > 0) {
                // Pega o caminho relativo do primeiro arquivo (ex: "Lote123/arquivo.pdf")
                const path = input.files[0].webkitRelativePath;
                const nomePastaRaiz = path.split('/')[0];

                // Atualiza UI
                numLoteInput.value = nomePastaRaiz;
                pastaInput.value = nomePastaRaiz; // Caso precise enviar o nome separadamente

                fileFeedback.classList.remove('hidden');
                folderNameDisplay.textContent = `Pasta: ${nomePastaRaiz} (${input.files.length} arquivos)`;

                // Chama API
                await verificarLote(nomePastaRaiz);
            } else {
                limparSelecao();
            }
        });

        // --- Função para limpar seleção ---
        function limparSelecao() {
            numLoteInput.value = '';
            idLoteInput.value = '';
            fileFeedback.classList.add('hidden');
            statusText.textContent = 'Selecione a pasta para gerar o número.';
            statusText.className = 'text-xs text-gray-500';
        }

        // --- Chamada API ---
        async function verificarLote(nomeLote) {
            // UI Loading
            loadingSpinner.classList.remove('hidden');
            statusText.textContent = 'Verificando lote no sistema...';
            statusText.className = 'text-xs text-blue-600 font-semibold';
            numLoteInput.classList.add('opacity-50');

            try {
                const response = await fetch("/Scan/GetLote/", {
                    method: "POST",
                    headers: {
                        "Content-Type": "application/json"
                    },
                    body: JSON.stringify(nomeLote)
                });

                if (!response.ok) {
                    throw new Error(`Erro ${response.status}: Falha ao consultar lote`);
                }

                const data = await response.json();

                // Sucesso
                if (data && data.id) {
                    idLoteInput.value = data.id; // Assume que o retorno tem propriedade 'id'
                    statusText.textContent = 'Lote verificado e vinculado com sucesso!';
                    statusText.className = 'text-xs text-green-600 font-bold';
                    showToast('Lote vinculado com sucesso!', 'success');
                } else {
                    // Caso a API retorne 200 mas sem dados válidos
                    idLoteInput.value = data.numlote || ''; // Fallback
                    statusText.textContent = 'Lote novo identificado.';
                    statusText.className = 'text-xs text-blue-600';
                }

            } catch (error) {
                console.error("Erro:", error);
                statusText.textContent = 'Erro ao verificar lote. Verifique o console.';
                statusText.className = 'text-xs text-red-500 font-bold';
                showToast('Erro ao comunicar com o servidor.', 'error');
            } finally {
                loadingSpinner.classList.add('hidden');
                numLoteInput.classList.remove('opacity-50');
            }
        }

        // --- Validação do Submit ---
        form.addEventListener('submit', (e) => {
            const files = input.files;

            if (files.length === 0) {
                e.preventDefault();
                showToast('Por favor, selecione uma pasta antes de salvar.', 'warning');

                // Animação de erro no container de upload
                const uploadArea = input.closest('.border-dashed');
                uploadArea.classList.add('border-red-400', 'bg-red-50');
                setTimeout(() => {
                    uploadArea.classList.remove('border-red-400', 'bg-red-50');
                }, 2000);
            }

            // Se tiver arquivos, o form segue naturalmente
        });

        // --- Função Utilitária de Toast ---
        function showToast(message, type = 'info') {
            const toast = document.getElementById('toast');
            const msg = document.getElementById('toastMessage');
            const icon = document.getElementById('toastIcon');

            msg.textContent = message;

            // Configura cores e ícones
            if (type === 'success') {
                icon.className = 'fas fa-check-circle text-green-400';
            } else if (type === 'error') {
                icon.className = 'fas fa-times-circle text-red-400';
            } else if (type === 'warning') {
                icon.className = 'fas fa-exclamation-triangle text-yellow-400';
            } else {
                icon.className = 'fas fa-info-circle text-blue-400';
            }

            // Mostra
            toast.classList.remove('translate-y-20', 'opacity-0');

            // Esconde depois de 3s
            setTimeout(() => {
                toast.classList.add('translate-y-20', 'opacity-0');
            }, 3000);
        }
    });
</script>